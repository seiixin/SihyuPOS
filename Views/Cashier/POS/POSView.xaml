<UserControl
    x:Class="SihyuPOSPayroll.Views.Cashier.POS.POSView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:helpers="clr-namespace:SihyuPOSPayroll.Helpers"
    Background="#000000">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <helpers:EnumToBoolConverter x:Key="EnumToBoolConverter"/>
        <helpers:EmptyStringToVisibilityConverter x:Key="EmptyStringToVisibilityConverter"/>
    </UserControl.Resources>

    <Grid Margin="28,24,28,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ── Page Header ── -->
        <Border BorderBrush="#072219" BorderThickness="0,0,0,1"
                Margin="0,0,0,20" Padding="0,0,0,14">
            <TextBlock Text="POS Panel"
                       FontSize="26"
                       FontWeight="Bold"
                       Foreground="#477C60"/>
        </Border>

        <!-- ── Main two-column layout ── -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="3*"/>
            </Grid.ColumnDefinitions>

            <!-- ============================================================
                 LEFT  –  Product Browser
                 ============================================================ -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Search + Category row -->
                <Grid Grid.Row="0" Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="180"/>
                    </Grid.ColumnDefinitions>

                    <!-- Search box -->
                    <Border Grid.Column="0"
                            Background="#090B17"
                            CornerRadius="8"
                            BorderBrush="#1A1D2E"
                            BorderThickness="1"
                            Padding="12,0"
                            Height="40">
                        <Grid>
                            <TextBlock Text="&#xE721;"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="13"
                                       Foreground="#6B7280"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Left"/>
                            <TextBox x:Name="SearchBox"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     Foreground="#F3F4F6"
                                     VerticalContentAlignment="Center"
                                     Margin="22,0,0,0"
                                     TextChanged="SearchBox_TextChanged"/>
                            <TextBlock Text="Search products…"
                                       Foreground="#6B7280"
                                       Margin="24,0,0,0"
                                       VerticalAlignment="Center"
                                       IsHitTestVisible="False"
                                       Visibility="{Binding Text, ElementName=SearchBox,
                                                    Converter={StaticResource EmptyStringToVisibilityConverter}}"/>
                        </Grid>
                    </Border>

                    <!-- Category ComboBox -->
                    <ComboBox Grid.Column="2"
                              x:Name="CategoryCombo"
                              Height="40"
                              SelectionChanged="CategoryCombo_SelectionChanged"/>
                </Grid>

                <!-- Column headers for product list -->
                <Border Grid.Row="1"
                        Background="#090B17"
                        CornerRadius="8,8,0,0"
                        Padding="12,10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="90"/>
                            <ColumnDefinition Width="80"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Product"
                                   FontWeight="SemiBold"
                                   Foreground="#9CA3AF"
                                   FontSize="12"/>
                        <TextBlock Grid.Column="1"
                                   Text="Price"
                                   FontWeight="SemiBold"
                                   Foreground="#9CA3AF"
                                   FontSize="12"
                                   HorizontalAlignment="Right"/>
                        <TextBlock Grid.Column="2"
                                   FontWeight="SemiBold"
                                   Foreground="#9CA3AF"
                                   FontSize="12"
                                   HorizontalAlignment="Center"/>
                    </Grid>
                </Border>

                <!-- Product list -->
                <Border Grid.Row="2"
                        Background="#090B17"
                        CornerRadius="0,0,10,10">
                    <ListView x:Name="ProductList"
                              Background="Transparent"
                              BorderThickness="0"
                              ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Padding" Value="12,0"/>
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                <Setter Property="BorderBrush" Value="#0F1220"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#0D0F1A"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid Height="44">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="90"/>
                                        <ColumnDefinition Width="80"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{Binding Name}"
                                               Foreground="#F3F4F6"
                                               FontSize="14"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding Price, StringFormat=₱{0:N2}}"
                                               Foreground="#9CA3AF"
                                               FontSize="13"
                                               HorizontalAlignment="Right"
                                               VerticalAlignment="Center"/>
                                    <Button Grid.Column="2"
                                            Content="+ Add"
                                            Click="AddProduct_Click"
                                            Style="{StaticResource PrimaryButton}"
                                            Padding="8,4"
                                            FontSize="12"
                                            HorizontalAlignment="Center"/>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Border>
            </Grid>

            <!-- ============================================================
                 RIGHT  –  Order Editor
                 ============================================================ -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Order header: title + Payment + Status + Total -->
                <Border Grid.Row="0"
                        Background="#090B17"
                        CornerRadius="10,10,0,0"
                        Padding="16,14">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0"
                                   Text="Create Order"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Foreground="#F3F4F6"
                                   VerticalAlignment="Center"/>

                        <!-- Payment -->
                        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="Payment:"
                                       Foreground="#9CA3AF"
                                       FontSize="13"
                                       VerticalAlignment="Center"
                                       Margin="0,0,8,0"/>
                            <ComboBox Width="110"
                                      ItemsSource="{Binding PaymentStatuses}"
                                      SelectedItem="{Binding EditingOrder.PaymentStatus, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>

                        <!-- Status -->
                        <StackPanel Grid.Column="4" Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="Status:"
                                       Foreground="#9CA3AF"
                                       FontSize="13"
                                       VerticalAlignment="Center"
                                       Margin="0,0,8,0"/>
                            <ComboBox Width="130"
                                      ItemsSource="{Binding OrderStatuses}"
                                      SelectedItem="{Binding EditingOrder.OrderStatus, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>

                        <!-- Total -->
                        <StackPanel Grid.Column="6" Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="Total:"
                                       Foreground="#9CA3AF"
                                       FontSize="13"
                                       VerticalAlignment="Center"
                                       Margin="0,0,8,0"/>
                            <TextBlock Text="{Binding EditingOrder.TotalAmount, StringFormat=₱{0:N2}}"
                                       FontSize="16"
                                       FontWeight="Bold"
                                       Foreground="#128854"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Column header bar -->
                <Border Grid.Row="1"
                        Background="#0D1117"
                        Padding="0">
                    <DataGrid x:Name="ItemsHeaderGrid"
                              IsReadOnly="True"
                              HeadersVisibility="Column"
                              Background="Transparent"
                              BorderThickness="0"
                              ColumnHeaderHeight="40"
                              RowHeight="0"
                              Visibility="Collapsed"/>
                </Border>

                <!-- Items DataGrid -->
                <Border Grid.Row="2"
                        Background="#090B17"
                        CornerRadius="0">
                    <DataGrid x:Name="ItemsGrid"
                              ItemsSource="{Binding EditingItems}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              IsReadOnly="False"
                              HeadersVisibility="Column"
                              Background="Transparent"
                              BorderThickness="0"
                              GridLinesVisibility="Horizontal"
                              HorizontalGridLinesBrush="#0F1220"
                              ColumnHeaderHeight="44"
                              RowHeight="48"
                              CellEditEnding="ItemsGrid_CellEditEnding">
                        <DataGrid.Resources>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background" Value="#0D1117"/>
                                <Setter Property="Foreground" Value="#9CA3AF"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter Property="FontSize" Value="12"/>
                                <Setter Property="Padding" Value="12,8"/>
                                <Setter Property="BorderBrush" Value="#0F1220"/>
                                <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                <Setter Property="HorizontalContentAlignment" Value="Left"/>
                            </Style>
                        </DataGrid.Resources>
                        <DataGrid.Columns>
                            <DataGridTemplateColumn Header="Product" Width="2.5*">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding ProductName}"
                                                   Foreground="#F3F4F6"
                                                   VerticalAlignment="Center"
                                                   Margin="4,0"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                                <DataGridTemplateColumn.CellEditingTemplate>
                                    <DataTemplate>
                                        <ComboBox ItemsSource="{Binding DataContext.MenuProducts, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                  DisplayMemberPath="Name"
                                                  SelectedValuePath="Id"
                                                  SelectedValue="{Binding ProductId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                  SelectionChanged="ProductCombo_SelectionChanged"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellEditingTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTextColumn Header="Qty"
                                                Binding="{Binding Quantity, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                Width="0.8*"/>

                            <DataGridTextColumn Header="Unit Price"
                                                Binding="{Binding UnitPrice, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, StringFormat=\{0:0.##\}}"
                                                Width="1.2*"/>

                            <DataGridTextColumn Header="Subtotal"
                                                IsReadOnly="True"
                                                Binding="{Binding Subtotal, StringFormat=\{0:0.##\}}"
                                                Width="1.2*"/>

                            <DataGridTemplateColumn Header="Actions" Width="0.9*">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="Remove"
                                                ToolTip="Remove item"
                                                Click="RemoveLine_Click"
                                                Style="{StaticResource DangerButton}"
                                                Padding="8,4"
                                                FontSize="12"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>

                <!-- Footer: Order Type (RestaurantMode) + action buttons -->
                <Border Grid.Row="3"
                        Background="#090B17"
                        CornerRadius="0,0,10,10"
                        Padding="16,12"
                        BorderBrush="#0F1220"
                        BorderThickness="0,1,0,0">
                    <DockPanel LastChildFill="False">

                        <!-- Order Type (RestaurantMode only) -->
                        <StackPanel DockPanel.Dock="Left"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Center"
                                    Visibility="{Binding IsOrderTypeRequired, Converter={StaticResource BoolToVisibilityConverter}}"
                                    Margin="0,0,16,0">
                            <TextBlock Text="Order Type:"
                                       Foreground="#9CA3AF"
                                       VerticalAlignment="Center"
                                       Margin="0,0,10,0"/>
                            <RadioButton Content="Dine-In"
                                         Foreground="#F3F4F6"
                                         Margin="0,0,10,0"
                                         GroupName="OrderType"
                                         IsChecked="{Binding SelectedOrderType, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=DineIn}"/>
                            <RadioButton Content="Take-Out"
                                         Foreground="#F3F4F6"
                                         Margin="0,0,16,0"
                                         GroupName="OrderType"
                                         IsChecked="{Binding SelectedOrderType, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=TakeOut}"/>
                            <TextBlock Text="Please select Dine-In or Take-Out"
                                       Foreground="#EF4444"
                                       VerticalAlignment="Center"
                                       FontSize="12">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <MultiDataTrigger>
                                                <MultiDataTrigger.Conditions>
                                                    <Condition Binding="{Binding IsOrderTypeRequired}" Value="True"/>
                                                    <Condition Binding="{Binding CanConfirmOrder}" Value="False"/>
                                                </MultiDataTrigger.Conditions>
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </MultiDataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>

                        <!-- Action buttons -->
                        <StackPanel DockPanel.Dock="Right"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Center">
                            <Button Content="+ Add Item"
                                    Style="{StaticResource SecondaryButton}"
                                    Margin="0,0,8,0"
                                    Click="AddLine_Click"/>
                            <Button Content="Save Order"
                                    Style="{StaticResource PrimaryButton}"
                                    Margin="0,0,8,0"
                                    Click="SaveEditor_Click"
                                    IsEnabled="{Binding CanConfirmOrder}"/>
                            <Button Content="Cancel"
                                    Style="{StaticResource SecondaryButton}"
                                    Click="CancelEditor_Click"/>
                        </StackPanel>
                    </DockPanel>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
