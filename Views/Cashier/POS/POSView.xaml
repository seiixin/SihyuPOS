<UserControl
    x:Class="SihyuPOSPayroll.Views.Cashier.POS.POSView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:helpers="clr-namespace:SihyuPOSPayroll.Helpers"
    Background="#000000">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <helpers:EnumToBoolConverter x:Key="EnumToBoolConverter"/>
        <helpers:EmptyStringToVisibilityConverter x:Key="EmptyStringToVisibilityConverter"/>

        <!-- ── Product card style ───────────────────────────────────────── -->
        <Style x:Key="ProductCardItem" TargetType="ListViewItem">
            <Setter Property="Padding"                  Value="0"/>
            <Setter Property="Margin"                   Value="0,0,12,12"/>
            <Setter Property="Background"               Value="Transparent"/>
            <Setter Property="BorderThickness"          Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="FocusVisualStyle"         Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListViewItem">
                        <ContentPresenter/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Margin="28,24,28,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ── Page Header ── -->
        <Border BorderBrush="#072219" BorderThickness="0,0,0,1"
                Margin="0,0,0,20" Padding="0,0,0,14">
            <TextBlock Text="POS Panel"
                       FontSize="26" FontWeight="Bold" Foreground="#477C60"/>
        </Border>

        <!-- ── Main two-column layout ── -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2.2*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="2.8*"/>
            </Grid.ColumnDefinitions>

            <!-- ============================================================
                 LEFT  –  Product Card Grid
                 ============================================================ -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Search + Category toolbar -->
                <Grid Grid.Row="0" Margin="0,0,0,14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="160"/>
                    </Grid.ColumnDefinitions>

                    <!-- Search box -->
                    <Border Background="#090B17"
                            CornerRadius="8"
                            BorderBrush="#1A1D2E"
                            BorderThickness="1"
                            Padding="12,0"
                            Height="40">
                        <Grid>
                            <TextBlock Text="&#xE721;"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="13"
                                       Foreground="#6B7280"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Left"/>
                            <TextBox x:Name="SearchBox"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     Foreground="#F3F4F6"
                                     VerticalContentAlignment="Center"
                                     Margin="22,0,0,0"
                                     TextChanged="SearchBox_TextChanged"/>
                            <TextBlock Text="Search products…"
                                       Foreground="#6B7280"
                                       Margin="24,0,0,0"
                                       VerticalAlignment="Center"
                                       IsHitTestVisible="False"
                                       Visibility="{Binding Text, ElementName=SearchBox,
                                                    Converter={StaticResource EmptyStringToVisibilityConverter}}"/>
                        </Grid>
                    </Border>

                    <!-- Category ComboBox -->
                    <ComboBox Grid.Column="2"
                              x:Name="CategoryCombo"
                              Height="40"
                              SelectionChanged="CategoryCombo_SelectionChanged"/>
                </Grid>

                <!-- Product card grid (WrapPanel inside ScrollViewer) -->
                <ScrollViewer Grid.Row="1"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <ListView x:Name="ProductList"
                              Background="Transparent"
                              BorderThickness="0"
                              ItemContainerStyle="{StaticResource ProductCardItem}"
                              ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                              ScrollViewer.VerticalScrollBarVisibility="Disabled">
                        <!-- WrapPanel: 3-column auto-wrapping card grid -->
                        <ListView.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ListView.ItemsPanel>
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <!-- ── Product Card ────────────────────── -->
                                <Border Width="148"
                                        Background="#090B17"
                                        CornerRadius="12"
                                        BorderBrush="#1A1D2E"
                                        BorderThickness="1"
                                        Padding="0,0,0,12"
                                        Margin="0,0,0,0">
                                    <StackPanel>
                                        <!-- Product image / placeholder -->
                                        <Border CornerRadius="12,12,0,0"
                                                Height="100"
                                                ClipToBounds="True"
                                                Background="#0D0F1A">
                                            <Grid>
                                                <!-- Category initial badge -->
                                                <Border Width="52" Height="52"
                                                        CornerRadius="26"
                                                        Background="#072219"
                                                        HorizontalAlignment="Center"
                                                        VerticalAlignment="Center">
                                                    <TextBlock Text="&#xE8B9;"
                                                               FontFamily="Segoe MDL2 Assets"
                                                               FontSize="22"
                                                               Foreground="#128854"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"/>
                                                </Border>
                                            </Grid>
                                        </Border>

                                        <!-- Name -->
                                        <TextBlock Text="{Binding Name}"
                                                   Foreground="#F3F4F6"
                                                   FontSize="13"
                                                   FontWeight="SemiBold"
                                                   TextWrapping="Wrap"
                                                   MaxHeight="38"
                                                   Margin="10,10,10,6"
                                                   TextTrimming="CharacterEllipsis"/>

                                        <!-- Price + Add button row -->
                                        <Grid Margin="10,0,10,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- Price -->
                                            <TextBlock Text="{Binding Price, StringFormat=₱{0:N2}}"
                                                       Foreground="#10B981"
                                                       FontSize="14"
                                                       FontWeight="Bold"
                                                       VerticalAlignment="Center"/>

                                            <!-- Circular + button -->
                                            <Button Grid.Column="1"
                                                    Content="+"
                                                    Click="AddProduct_Click"
                                                    Width="32" Height="32"
                                                    Cursor="Hand"
                                                    FontSize="18"
                                                    FontWeight="Bold"
                                                    Foreground="#000000">
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border x:Name="Bg"
                                                                Width="32" Height="32"
                                                                CornerRadius="16"
                                                                Background="#10B981">
                                                            <ContentPresenter HorizontalAlignment="Center"
                                                                              VerticalAlignment="Center"/>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="Bg" Property="Background" Value="#128854"/>
                                                            </Trigger>
                                                            <Trigger Property="IsPressed" Value="True">
                                                                <Setter TargetName="Bg" Property="Opacity" Value="0.8"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Button.Template>
                                            </Button>
                                        </Grid>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </ScrollViewer>
            </Grid>

            <!-- ============================================================
                 RIGHT  –  Current Order Panel
                 ============================================================ -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Order header -->
                <Border Grid.Row="0"
                        Background="#090B17"
                        CornerRadius="10,10,0,0"
                        Padding="16,14">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="Current Order"
                                   FontSize="17" FontWeight="Bold"
                                   Foreground="#F3F4F6"
                                   VerticalAlignment="Center"/>

                        <!-- Payment -->
                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="Payment:"
                                       Foreground="#6B7280" FontSize="12"
                                       VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <ComboBox Width="105"
                                      ItemsSource="{Binding PaymentStatuses}"
                                      SelectedItem="{Binding EditingPaymentStatus, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>

                        <!-- Status -->
                        <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="Status:"
                                       Foreground="#6B7280" FontSize="12"
                                       VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <ComboBox Width="120"
                                      ItemsSource="{Binding OrderStatuses}"
                                      SelectedItem="{Binding EditingOrderStatus, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Order items DataGrid -->
                <Border Grid.Row="1" Background="#090B17">
                    <DataGrid x:Name="ItemsGrid"
                              ItemsSource="{Binding EditingItems}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              IsReadOnly="False"
                              HeadersVisibility="Column"
                              Background="Transparent"
                              BorderThickness="0"
                              GridLinesVisibility="Horizontal"
                              HorizontalGridLinesBrush="#0F1220"
                              ColumnHeaderHeight="40"
                              RowHeight="52"
                              CellEditEnding="ItemsGrid_CellEditEnding">
                        <DataGrid.Resources>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background" Value="#0D1117"/>
                                <Setter Property="Foreground" Value="#6B7280"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter Property="FontSize" Value="11"/>
                                <Setter Property="Padding" Value="12,8"/>
                                <Setter Property="BorderBrush" Value="#0F1220"/>
                                <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                <Setter Property="HorizontalContentAlignment" Value="Left"/>
                            </Style>
                        </DataGrid.Resources>
                        <DataGrid.Columns>
                            <!-- Product with qty controls -->
                            <DataGridTemplateColumn Header="Item" Width="2*">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Margin="8,0">
                                            <TextBlock Text="{Binding ProductName}"
                                                       Foreground="#F3F4F6"
                                                       FontSize="13" FontWeight="SemiBold"/>
                                            <TextBlock Text="{Binding UnitPrice, StringFormat=₱{0:N2} each}"
                                                       Foreground="#6B7280"
                                                       FontSize="11"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                                <DataGridTemplateColumn.CellEditingTemplate>
                                    <DataTemplate>
                                        <ComboBox ItemsSource="{Binding DataContext.MenuProducts, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                  DisplayMemberPath="Name"
                                                  SelectedValuePath="Id"
                                                  SelectedValue="{Binding ProductId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                  SelectionChanged="ProductCombo_SelectionChanged"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellEditingTemplate>
                            </DataGridTemplateColumn>

                            <!-- Qty with − / + inline -->
                            <DataGridTemplateColumn Header="Qty" Width="100">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal"
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center">
                                            <Button Content="−"
                                                    Width="24" Height="24"
                                                    FontSize="14" FontWeight="Bold"
                                                    Foreground="#F3F4F6"
                                                    Cursor="Hand"
                                                    Click="DecrQty_Click">
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border x:Name="Bg" CornerRadius="12"
                                                                Background="#1A1D2E"
                                                                Width="24" Height="24">
                                                            <ContentPresenter HorizontalAlignment="Center"
                                                                              VerticalAlignment="Center"/>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="Bg" Property="Background" Value="#272A3A"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Button.Template>
                                            </Button>
                                            <TextBlock Text="{Binding Quantity}"
                                                       Foreground="#F3F4F6"
                                                       FontSize="14" FontWeight="SemiBold"
                                                       Width="28"
                                                       TextAlignment="Center"
                                                       VerticalAlignment="Center"/>
                                            <Button Content="+"
                                                    Width="24" Height="24"
                                                    FontSize="14" FontWeight="Bold"
                                                    Foreground="#000000"
                                                    Cursor="Hand"
                                                    Click="IncrQty_Click">
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border x:Name="Bg" CornerRadius="12"
                                                                Background="#10B981"
                                                                Width="24" Height="24">
                                                            <ContentPresenter HorizontalAlignment="Center"
                                                                              VerticalAlignment="Center"/>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="Bg" Property="Background" Value="#128854"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Button.Template>
                                            </Button>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTextColumn Header="Subtotal"
                                                IsReadOnly="True"
                                                Binding="{Binding Subtotal, StringFormat=₱{0:N2}}"
                                                Width="1.1*"/>

                            <DataGridTemplateColumn Header="" Width="36">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="✕"
                                                ToolTip="Remove"
                                                Click="RemoveLine_Click"
                                                Cursor="Hand"
                                                FontSize="12"
                                                Foreground="#6B7280"
                                                Width="28" Height="28">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="Bg" CornerRadius="6"
                                                            Background="Transparent">
                                                        <ContentPresenter HorizontalAlignment="Center"
                                                                          VerticalAlignment="Center"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="Bg" Property="Background" Value="#331A1A"/>
                                                            <Setter Property="Foreground" Value="#EF4444"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>

                <!-- Total summary bar -->
                <Border Grid.Row="2"
                        Background="#0D1117"
                        Padding="16,12"
                        BorderBrush="#072219"
                        BorderThickness="0,1,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Total"
                                   Foreground="#9CA3AF"
                                   FontSize="15" FontWeight="SemiBold"
                                   VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1"
                                   Text="{Binding EditingOrder.TotalAmount, StringFormat=₱{0:N2}}"
                                   Foreground="#10B981"
                                   FontSize="22" FontWeight="Bold"
                                   VerticalAlignment="Center"/>
                    </Grid>
                </Border>

                <!-- Footer: Order Type + action buttons -->
                <Border Grid.Row="3"
                        Background="#090B17"
                        CornerRadius="0,0,10,10"
                        Padding="16,12"
                        BorderBrush="#0F1220"
                        BorderThickness="0,1,0,0">
                    <DockPanel LastChildFill="False">

                        <!-- Order Type (RestaurantMode only) -->
                        <StackPanel DockPanel.Dock="Left"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Center"
                                    Visibility="{Binding IsOrderTypeRequired, Converter={StaticResource BoolToVisibilityConverter}}"
                                    Margin="0,0,16,0">
                            <TextBlock Text="Order Type:"
                                       Foreground="#9CA3AF"
                                       VerticalAlignment="Center"
                                       Margin="0,0,10,0"/>
                            <RadioButton Content="Dine-In"
                                         Foreground="#F3F4F6"
                                         Margin="0,0,10,0"
                                         GroupName="OrderType"
                                         IsChecked="{Binding SelectedOrderType, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=DineIn}"/>
                            <RadioButton Content="Take-Out"
                                         Foreground="#F3F4F6"
                                         Margin="0,0,16,0"
                                         GroupName="OrderType"
                                         IsChecked="{Binding SelectedOrderType, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=TakeOut}"/>
                            <TextBlock Text="Please select Dine-In or Take-Out"
                                       Foreground="#EF4444"
                                       VerticalAlignment="Center"
                                       FontSize="12">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <MultiDataTrigger>
                                                <MultiDataTrigger.Conditions>
                                                    <Condition Binding="{Binding IsOrderTypeRequired}" Value="True"/>
                                                    <Condition Binding="{Binding CanConfirmOrder}" Value="False"/>
                                                </MultiDataTrigger.Conditions>
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </MultiDataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>

                        <!-- Action buttons -->
                        <StackPanel DockPanel.Dock="Right"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Center">
                            <Button Content="+ Add Item"
                                    Style="{StaticResource SecondaryButton}"
                                    Margin="0,0,8,0"
                                    Click="AddLine_Click"/>
                            <Button Content="Save Order"
                                    Style="{StaticResource PrimaryButton}"
                                    Margin="0,0,8,0"
                                    Click="SaveEditor_Click"
                                    IsEnabled="{Binding CanConfirmOrder}"/>
                            <Button Content="Cancel"
                                    Style="{StaticResource SecondaryButton}"
                                    Click="CancelEditor_Click"/>
                        </StackPanel>
                    </DockPanel>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
