<UserControl x:Class="SihyuPOSPayroll.Views.Admin.Receipts.Receipts"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:helpers="clr-namespace:SihyuPOSPayroll.Helpers"
             Background="#000000">

    <UserControl.Resources>
        <helpers:EmptyStringToVisibilityConverter x:Key="EmptyStringToVisibilityConverter"/>
    </UserControl.Resources>

    <Grid Margin="28,24,28,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Page Header -->
        <Border BorderBrush="#072219" BorderThickness="0,0,0,1" Margin="0,0,0,20" Padding="0,0,0,14">
            <TextBlock Text="Receipts"
                       FontSize="26"
                       FontWeight="Bold"
                       Foreground="#477C60"/>
        </Border>

        <!-- Search + actions -->
        <Grid Grid.Row="1" Margin="0,0,0,14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Border Background="#090B17"
                    CornerRadius="8"
                    BorderBrush="#0D1117"
                    BorderThickness="1"
                    Padding="12,0"
                    Height="40"
                    Margin="0,0,10,0">
                <Grid>
                    <TextBlock Text="&#xE721;"
                               FontFamily="Segoe MDL2 Assets"
                               FontSize="13"
                               Foreground="#6B7280"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Left"/>
                    <TextBox x:Name="SearchBox"
                             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                             Background="Transparent"
                             BorderThickness="0"
                             Foreground="#F3F4F6"
                             VerticalContentAlignment="Center"
                             Margin="22,0,0,0"/>
                    <TextBlock Text="Search Order ID, Table, or Date"
                               Foreground="#6B7280"
                               Margin="24,0,0,0"
                               VerticalAlignment="Center"
                               IsHitTestVisible="False"
                               Visibility="{Binding Text.Length, ElementName=SearchBox, Converter={StaticResource EmptyStringToVisibilityConverter}}"/>
                </Grid>
            </Border>
            <Button Grid.Column="1" Content="Search" Command="{Binding SearchCommand}" Style="{StaticResource PrimaryButton}" Margin="0,0,8,0"/>
            <Button Grid.Column="2" Content="Clear" Command="{Binding ClearSearchCommand}" Style="{StaticResource SecondaryButton}" Margin="0,0,8,0"/>
            <Button Grid.Column="3" Content="Refresh" Command="{Binding RefreshCommand}" Style="{StaticResource PrimaryButton}"/>
        </Grid>

        <!-- Receipts grid -->
        <Border Grid.Row="2" Background="#090B17" CornerRadius="10" Padding="0">
            <DataGrid ItemsSource="{Binding Receipts}"
                      SelectedItem="{Binding Selected, Mode=TwoWay}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      IsReadOnly="True"
                      BorderThickness="0"
                      Background="#090B17"
                      GridLinesVisibility="None"
                      ColumnHeaderHeight="44"
                      RowHeight="48">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Receipt ID" Binding="{Binding ReceiptId}" Width="1.2*"/>
                    <DataGridTextColumn Header="Order ID"   Binding="{Binding OrderId}"   Width="1.2*"/>
                    <DataGridTextColumn Header="Table"      Binding="{Binding TableNumber}" Width="1.0*"/>
                    <DataGridTextColumn Header="Date"       Binding="{Binding Date}"       Width="1.4*"/>
                    <DataGridTextColumn Header="Amount"     Binding="{Binding Amount, StringFormat=\{0:0.##\}}" Width="1.2*"/>
                    <DataGridTemplateColumn Header="Actions" Width="1.2*">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <Button Content="Print"
                                            Command="{Binding DataContext.PrintCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding ReceiptId}"
                                            Style="{StaticResource PrimaryButton}"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</UserControl>
