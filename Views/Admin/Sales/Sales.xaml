<UserControl x:Class="SihyuPOSPayroll.Views.Admin.Sales.Sales"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#000000">
    <Grid Margin="28,24,28,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Page Header -->
        <Border BorderBrush="#072219" BorderThickness="0,0,0,1" Margin="0,0,0,20" Padding="0,0,0,14">
            <TextBlock Text="Sales &amp; Receipts Summary"
                       FontSize="26"
                       FontWeight="Bold"
                       Foreground="#477C60"/>
        </Border>

        <!-- Controls -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,14">
            <TextBlock Text="Report Period:" Foreground="#9CA3AF" VerticalAlignment="Center" Margin="0,0,8,0"/>
            <ComboBox Width="160"
                      ItemsSource="{Binding PeriodChoices}"
                      SelectedItem="{Binding SelectedPeriod}"
                      Margin="0,0,16,0"/>
            <Button Content="Generate" Width="120" Margin="0,0,8,0"
                    Style="{StaticResource PrimaryButton}"
                    Command="{Binding GenerateCommand}"/>
            <Button Content="Export CSV" Width="120" Margin="0,0,8,0"
                    Style="{StaticResource SecondaryButton}"
                    Command="{Binding ExportCsvCommand}"/>
            <Button Content="Export PDF" Width="120"
                    Style="{StaticResource SecondaryButton}"
                    Command="{Binding ExportPdfCommand}"/>
        </StackPanel>

        <!-- Grid -->
        <Border Grid.Row="2" Background="#090B17" CornerRadius="10" Padding="0">
            <DataGrid ItemsSource="{Binding Rows}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      IsReadOnly="True"
                      BorderThickness="0"
                      Background="#090B17"
                      GridLinesVisibility="None"
                      ColumnHeaderHeight="44"
                      RowHeight="48">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Period"   Binding="{Binding Period}" Width="2*"/>
                    <DataGridTextColumn Header="From"     Binding="{Binding StartDate, StringFormat=\{0:yyyy-MM-dd\}}" Width="*"/>
                    <DataGridTextColumn Header="To"       Binding="{Binding EndDate, StringFormat=\{0:yyyy-MM-dd\}}" Width="*"/>
                    <DataGridTextColumn Header="Receipts" Binding="{Binding ReceiptCount}" Width="*"/>
                    <DataGridTextColumn Header="Total"    Binding="{Binding TotalAmount, StringFormat=\{0:0.##\}}" Width="*"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- Footer totals -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
            <TextBlock Text="{Binding TotalReceipts, StringFormat=Receipts: {0}}"
                       Foreground="#9CA3AF" Margin="0,0,16,0"/>
            <TextBlock Text="{Binding GrandTotal, StringFormat=Total: {0:0.##}}"
                       Foreground="#128854" FontWeight="Bold"/>
        </StackPanel>
    </Grid>
</UserControl>
