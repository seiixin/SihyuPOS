<UserControl
    x:Class="SihyuPOSPayroll.Views.Admin.Employees.Employees"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:helpers="clr-namespace:SihyuPOSPayroll.Helpers"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="#000000"
    d:DesignHeight="310"
    d:DesignWidth="773">

    <UserControl.Resources>
        <helpers:EmptyStringToVisibilityConverter x:Key="EmptyStringToVisibilityConverter" />
        <helpers:BoolToBrushConverter x:Key="BoolToBrush" />
        <helpers:BoolToTextConverter  x:Key="BoolToText" />
    </UserControl.Resources>

    <Grid x:Name="RootGrid" Margin="28,24,28,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Page Header -->
        <Border BorderBrush="#072219" BorderThickness="0,0,0,1" Margin="0,0,0,20" Padding="0,0,0,14">
            <TextBlock Text="Employee Management"
                       FontSize="26"
                       FontWeight="Bold"
                       Foreground="#477C60"/>
        </Border>

        <!-- Search + Add -->
        <Grid Grid.Row="1" Margin="0,0,0,14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Border Background="#090B17"
                    CornerRadius="8"
                    BorderBrush="#0D1117"
                    BorderThickness="1"
                    Padding="12,0"
                    Height="40"
                    Margin="0,0,12,0">
                <Grid>
                    <TextBlock Text="&#xE721;"
                               FontFamily="Segoe MDL2 Assets"
                               FontSize="13"
                               Foreground="#6B7280"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Left"/>
                    <TextBox x:Name="SearchBox"
                             Background="Transparent"
                             BorderThickness="0"
                             Foreground="#F3F4F6"
                             VerticalContentAlignment="Center"
                             Margin="22,0,0,0"
                             TextChanged="SearchBox_TextChanged" />
                    <TextBlock Text="Search employees..."
                               Foreground="#6B7280"
                               Margin="24,0,0,0"
                               VerticalAlignment="Center"
                               IsHitTestVisible="False"
                               Visibility="{Binding Text.Length, ElementName=SearchBox, Converter={StaticResource EmptyStringToVisibilityConverter}}" />
                </Grid>
            </Border>
            <Button x:Name="AddEmployeeButton"
                    Grid.Column="1"
                    Content="+ Add Employee"
                    Style="{StaticResource PrimaryButton}"
                    Padding="18,10"/>
        </Grid>

        <!-- DataGrid -->
        <Border Grid.Row="2" Background="#090B17" CornerRadius="10" Padding="0">
            <DataGrid x:Name="EmployeeDataGrid"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      IsReadOnly="True"
                      ColumnHeaderHeight="44"
                      RowHeight="48"
                      Background="#090B17"
                      BorderThickness="0"
                      RowBackground="#090B17"
                      AlternatingRowBackground="#000000">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Full Name"   Binding="{Binding FullName}"        Width="*" />
                    <DataGridTextColumn Header="Position"    Binding="{Binding Position}"        Width="*" />
                    <DataGridTextColumn Header="Contact No." Binding="{Binding ContactNumber}"   Width="*" />
                    <DataGridTextColumn Header="User ID"     Binding="{Binding UserAccount.Id}"  Width="*" />
                    <DataGridTemplateColumn Header="Status" Width="*">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <Ellipse Width="10" Height="10"
                                             Margin="0,0,8,0"
                                             Fill="{Binding UserAccount.IsActive, Converter={StaticResource BoolToBrush}}"/>
                                    <TextBlock VerticalAlignment="Center"
                                               Text="{Binding UserAccount.IsActive,
                                                      Converter={StaticResource BoolToText},
                                                      ConverterParameter=Active |Inactive |No Login}"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTemplateColumn Header="Actions" Width="180">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <Button Content="Edit"
                                            ToolTip="Edit"
                                            Style="{StaticResource SecondaryButton}"
                                            Margin="0,0,8,0"
                                            Padding="12,6"
                                            Click="EditEmployee_Click"/>
                                    <Button Content="Delete"
                                            ToolTip="Delete"
                                            Style="{StaticResource DangerButton}"
                                            Padding="12,6"
                                            Click="DeleteEmployee_Click"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</UserControl>
