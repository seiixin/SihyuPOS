<UserControl
    x:Class="SihyuPOSPayroll.Views.Admin.Payroll.Payroll"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:helpers="clr-namespace:SihyuPOSPayroll.Helpers"
    Background="#000000">

    <Grid x:Name="RootGrid" Margin="28,24,28,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Page Header -->
        <Border BorderBrush="#072219" BorderThickness="0,0,0,1" Margin="0,0,0,20" Padding="0,0,0,14">
            <TextBlock Text="Payroll Records"
                       FontSize="26"
                       FontWeight="Bold"
                       Foreground="#477C60"/>
        </Border>

        <!-- Search and Action Buttons -->
        <Grid Grid.Row="1" Margin="0,0,0,14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Border Background="#090B17"
                    CornerRadius="8"
                    BorderBrush="#0D1117"
                    BorderThickness="1"
                    Padding="12,0"
                    Height="40"
                    Margin="0,0,12,0">
                <TextBox x:Name="SearchBox"
                         Background="Transparent"
                         BorderThickness="0"
                         Foreground="#F3F4F6"
                         VerticalContentAlignment="Center"
                         TextChanged="SearchBox_TextChanged"/>
            </Border>
            <Button Grid.Column="1" Content="+ Add Payroll" Click="AddPayroll_Click" Style="{StaticResource PrimaryButton}"/>
            <Button Grid.Column="3" Content="Positions &amp; Salaries" Click="OpenPositionSalary_Click" Style="{StaticResource SecondaryButton}"/>
        </Grid>

        <!-- Period Toolbar -->
        <Grid Grid.Row="2" Margin="0,0,0,14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="180"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="160"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="160"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Period:" VerticalAlignment="Center" Foreground="#9CA3AF" Margin="0,0,8,0"/>
            <ComboBox x:Name="PeriodCombo" Grid.Column="1" VerticalAlignment="Center" SelectedIndex="0" Padding="8,6">
                <ComboBoxItem Content="FirstHalf"/>
                <ComboBoxItem Content="SecondHalf"/>
                <ComboBoxItem Content="Custom"/>
            </ComboBox>
            <TextBlock Grid.Column="3" Text="From:" VerticalAlignment="Center" Foreground="#9CA3AF" Margin="0,0,8,0">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding SelectedItem.Content, ElementName=PeriodCombo}" Value="Custom">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>
            <DatePicker x:Name="CustomStartPicker" Grid.Column="4" VerticalAlignment="Center" Padding="8,6">
                <DatePicker.Style>
                    <Style TargetType="DatePicker">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding SelectedItem.Content, ElementName=PeriodCombo}" Value="Custom">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </DatePicker.Style>
            </DatePicker>
            <TextBlock Grid.Column="6" Text="To:" VerticalAlignment="Center" Foreground="#9CA3AF" Margin="0,0,8,0">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding SelectedItem.Content, ElementName=PeriodCombo}" Value="Custom">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>
            <DatePicker x:Name="CustomEndPicker" Grid.Column="7" VerticalAlignment="Center" Padding="8,6">
                <DatePicker.Style>
                    <Style TargetType="DatePicker">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding SelectedItem.Content, ElementName=PeriodCombo}" Value="Custom">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </DatePicker.Style>
            </DatePicker>
            <Button Grid.Column="9" x:Name="GenerateButton" Content="Generate Payroll"
                    Click="GeneratePayroll_Click" Style="{StaticResource PrimaryButton}"/>
        </Grid>

        <!-- Payroll DataGrid -->
        <Border Grid.Row="3" Background="#090B17" CornerRadius="10" Padding="0">
            <DataGrid ItemsSource="{Binding PayrollList}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      IsReadOnly="True"
                      BorderThickness="0"
                      Background="#090B17"
                      GridLinesVisibility="None"
                      ColumnHeaderHeight="44"
                      RowHeight="48">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Employee ID"      Binding="{Binding EmployeeId}"                               Width="*"/>
                    <DataGridTextColumn Header="Full Name"        Binding="{Binding EmployeeFullName}"                         Width="*"/>
                    <DataGridTextColumn Header="Period Start"     Binding="{Binding StartDate, StringFormat=\{0:yyyy-MM-dd\}}" Width="*"/>
                    <DataGridTextColumn Header="Period End"       Binding="{Binding EndDate, StringFormat=\{0:yyyy-MM-dd\}}"   Width="*"/>
                    <DataGridTextColumn Header="Days Worked"      Binding="{Binding TotalDaysWorked}"                          Width="*"/>
                    <DataGridTextColumn Header="Gross Salary"     Binding="{Binding GrossSalary, StringFormat=\{0:N2\}}"       Width="*"/>
                    <DataGridTextColumn Header="SSS"              Binding="{Binding SssDeduction, StringFormat=\{0:N2\}}"      Width="*"/>
                    <DataGridTextColumn Header="PhilHealth"       Binding="{Binding PhilhealthDeduction, StringFormat=\{0:N2\}}" Width="*"/>
                    <DataGridTextColumn Header="Pag-IBIG"         Binding="{Binding PagibigDeduction, StringFormat=\{0:N2\}}"  Width="*"/>
                    <DataGridTextColumn Header="Other Deductions" Binding="{Binding OtherDeductions, StringFormat=\{0:N2\}}"   Width="*"/>
                    <DataGridTextColumn Header="Bonus"            Binding="{Binding Bonus, StringFormat=\{0:N2\}}"             Width="*"/>
                    <DataGridTextColumn Header="Net Salary"       Binding="{Binding NetSalary, StringFormat=\{0:N2\}}"         Width="*"/>
                    <DataGridTemplateColumn Header="Actions" Width="120">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <Button Content="Edit"
                                            Style="{StaticResource SecondaryButton}"
                                            Margin="0,0,8,0"
                                            Click="EditPayroll_Click"
                                            DataContext="{Binding}"/>
                                    <Button Content="Delete"
                                            Style="{StaticResource DangerButton}"
                                            Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</UserControl>
