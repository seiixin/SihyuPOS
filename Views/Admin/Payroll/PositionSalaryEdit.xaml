<UserControl
    x:Class="SihyuPOSPayroll.Views.Admin.Payroll.PositionSalaryEdit"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    x:Name="Root"
    Background="{StaticResource BackgroundDarkBrush}"
    Focusable="True">

    <!-- ? InputBindings must be directly under the root element -->
    <UserControl.InputBindings>
        <KeyBinding Modifiers="Control" Key="S"
                    Command="{Binding DataContext.SaveCommand, ElementName=Root}"/>
        <KeyBinding Key="F5"
                    Command="{Binding DataContext.ReloadCommand, ElementName=Root}"/>
        <KeyBinding Key="Escape"
                    Command="{Binding DataContext.CloseCommand, ElementName=Root}"/>
    </UserControl.InputBindings>

    <Border Style="{StaticResource CardBorder}" Width="520" VerticalAlignment="Center" HorizontalAlignment="Center">
        <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="580">
            <StackPanel>
                <TextBlock Text="Positions &amp; Salaries"
                           FontSize="20" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}"
                           Margin="0,0,0,20" TextAlignment="Center"/>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,16">
                    <Button Content="Reload" Command="{Binding ReloadCommand}" Style="{StaticResource SecondaryButton}" Margin="0,0,8,0"/>
                    <Button Content="Add Row" Command="{Binding AddCommand}" Style="{StaticResource SecondaryButton}" Margin="0,0,8,0"/>
                    <Button Content="Save" Command="{Binding SaveCommand}" Style="{StaticResource PrimaryButton}"/>
                </StackPanel>

                <TextBlock Text="Tip: Type a Position and Daily Rate below. Use Save to persist to DB."
                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,16"/>

                <DataGrid x:Name="RatesGrid"
                          ItemsSource="{Binding Rates}"
                          SelectedItem="{Binding Selected, Mode=TwoWay}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          HeadersVisibility="Column"
                          GridLinesVisibility="None"
                          RowHeight="48"
                          ColumnHeaderHeight="48"
                          Margin="0,0,0,16"
                          IsReadOnly="False"
                          VirtualizingPanel.IsVirtualizing="True"
                          VirtualizingPanel.ScrollUnit="Pixel"
                          KeyboardNavigation.TabNavigation="Cycle">
                    <DataGrid.Resources>
                        <!-- ? EventSetter is allowed; Setter for events is NOT -->
                        <Style x:Key="NumericTextBox" TargetType="TextBox">
                            <Setter Property="HorizontalContentAlignment" Value="Right"/>
                            <Setter Property="Padding" Value="8,6"/>
                            <EventSetter Event="PreviewTextInput" Handler="NumericOnly_PreviewTextInput"/>
                        </Style>
                    </DataGrid.Resources>

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Position"
                                            Width="*"
                                            Binding="{Binding Position, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                        <DataGridTextColumn Header="Daily Rate"
                                            Width="150"
                                            Binding="{Binding DailyRate, Mode=TwoWay, StringFormat=\{0:F2\}, UpdateSourceTrigger=PropertyChanged}">
                            <DataGridTextColumn.EditingElementStyle>
                                <Style TargetType="TextBox" BasedOn="{StaticResource NumericTextBox}"/>
                            </DataGridTextColumn.EditingElementStyle>
                        </DataGridTextColumn>

                        <DataGridCheckBoxColumn Header="Active"
                                                Width="90"
                                                Binding="{Binding IsActive, Mode=TwoWay}"/>

                        <DataGridTextColumn Header="Updated"
                                            Width="170"
                                            IsReadOnly="True"
                                            Binding="{Binding UpdatedAt, StringFormat=\{0:yyyy-MM-dd HH:mm\}}"/>

                        <DataGridTemplateColumn Header="Actions" Width="120">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                        <Button Content="Edit"
                                                ToolTip="Edit"
                                                Style="{StaticResource SecondaryButton}"
                                                Margin="0,0,8,0"
                                                Click="EditRow_Click"/>
                                        <Button Content="Delete"
                                                ToolTip="Delete"
                                                Style="{StaticResource DangerButton}"
                                                Click="DeleteRow_Click"/>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>

                <DockPanel>
                    <TextBlock Text="{Binding Status}" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                    <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                        <TextBlock Text="Busy: " Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <CheckBox IsChecked="{Binding IsBusy, Mode=OneWay}"
                                  IsEnabled="False"
                                  Focusable="False"
                                  VerticalAlignment="Center"
                                  Margin="0,0,16,0"/>
                        <Button Content="Close"
                                Command="{Binding CloseCommand}"
                                Style="{StaticResource SecondaryButton}"/>
                    </StackPanel>
                </DockPanel>
            </StackPanel>
        </ScrollViewer>
    </Border>
</UserControl>
