<UserControl x:Class="SihyuPOSPayroll.Views.Admin.Attendance.WorkScheduleEdit"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignWidth="520" d:DesignHeight="640"
             Background="{StaticResource BackgroundDarkBrush}"
             Focusable="True">

    <!-- Centered card container -->
    <Border Style="{StaticResource CardBorder}" Width="520" VerticalAlignment="Center" HorizontalAlignment="Center">
        <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="580">
            <StackPanel>
                <!-- Title -->
                <TextBlock Text="Work Days Schedule Setup"
                           FontSize="20"
                           FontWeight="Bold"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           Margin="0,0,0,16"
                           TextAlignment="Center"/>

                <!-- Toolbar -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,16">
                    <Button Content="Reload"
                            Command="{Binding ReloadCommand}"
                            Style="{StaticResource SecondaryButton}"
                            Margin="0,0,8,0"/>
                    <Button Content="Add Row"
                            Command="{Binding AddCommand}"
                            Style="{StaticResource SecondaryButton}"
                            Margin="0,0,8,0"/>
                    <Button Content="Save"
                            Command="{Binding SaveCommand}"
                            Style="{StaticResource PrimaryButton}"/>
                </StackPanel>

                <!-- Tip -->
                <TextBlock Text="Tip: Label can be 'MWF', 'TTh', or any name. Double-click the Days cell (or click Edit) to edit Mon-Sun."
                           Foreground="{StaticResource TextSecondaryBrush}"
                           Margin="0,0,0,16"/>

                <!-- DataGrid -->
                <DataGrid x:Name="SchedulesGrid"
                          ItemsSource="{Binding Schedules}"
                          SelectedItem="{Binding Selected, Mode=TwoWay}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          HeadersVisibility="Column"
                          GridLinesVisibility="None"
                          RowHeight="48"
                          ColumnHeaderHeight="48"
                          Margin="0,0,0,16"
                          IsReadOnly="False">
                    <DataGrid.Columns>
                        <!-- Label (editable) -->
                        <DataGridTextColumn Header="Label"
                                            Width="*"
                                            Binding="{Binding Label, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                        <!-- Days (pretty text when not editing; 7 checkboxes when editing) -->
                        <DataGridTemplateColumn Header="Days" Width="220">
                            <!-- display -->
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding DaysText}" Foreground="{StaticResource TextPrimaryBrush}"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>

                            <!-- edit -->
                            <DataGridTemplateColumn.CellEditingTemplate>
                                <DataTemplate>
                                    <WrapPanel>
                                        <CheckBox Content="Mon" IsChecked="{Binding Mon, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Margin="2,0"/>
                                        <CheckBox Content="Tue" IsChecked="{Binding Tue, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Margin="2,0"/>
                                        <CheckBox Content="Wed" IsChecked="{Binding Wed, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Margin="2,0"/>
                                        <CheckBox Content="Thu" IsChecked="{Binding Thu, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Margin="2,0"/>
                                        <CheckBox Content="Fri" IsChecked="{Binding Fri, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Margin="2,0"/>
                                        <CheckBox Content="Sat" IsChecked="{Binding Sat, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Margin="2,0"/>
                                        <CheckBox Content="Sun" IsChecked="{Binding Sun, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Margin="2,0"/>
                                    </WrapPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellEditingTemplate>
                        </DataGridTemplateColumn>

                        <!-- Active -->
                        <DataGridCheckBoxColumn Header="Active"
                                                Width="90"
                                                Binding="{Binding IsActive, Mode=TwoWay}"/>

                        <!-- Updated -->
                        <DataGridTextColumn Header="Updated"
                                            Width="170"
                                            IsReadOnly="True"
                                            Binding="{Binding UpdatedAt, StringFormat=\{0:yyyy-MM-dd HH:mm\}}"/>

                        <!-- Actions -->
                        <DataGridTemplateColumn Header="Actions" Width="120">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                        <!-- Edit: begin editing this row -->
                                        <Button Content="Edit"
                                                ToolTip="Edit"
                                                Style="{StaticResource SecondaryButton}"
                                                Margin="0,0,8,0"
                                                Click="EditRow_Click"/>

                                        <!-- Delete: remove from grid; persists after Save -->
                                        <Button Content="Delete"
                                                ToolTip="Delete"
                                                Style="{StaticResource DangerButton}"
                                                Click="DeleteRow_Click"/>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>

                <!-- Footer -->
                <DockPanel>
                    <TextBlock Text="{Binding Status}" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                    <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                        <TextBlock Text="Busy: " Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <CheckBox IsChecked="{Binding IsBusy, Mode=OneWay}"
                                  IsEnabled="False"
                                  Focusable="False"
                                  VerticalAlignment="Center"
                                  Margin="0,0,16,0"/>
                        <Button Content="Close"
                                Command="{Binding CloseCommand}"
                                Style="{StaticResource SecondaryButton}"/>
                    </StackPanel>
                </DockPanel>
            </StackPanel>
        </ScrollViewer>
    </Border>
</UserControl>
