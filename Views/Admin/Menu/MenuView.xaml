<UserControl
    x:Class="SihyuPOSPayroll.Views.Admin.Menu.MenuView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:viewmodels="clr-namespace:SihyuPOSPayroll.ViewModels"
    Background="#000000">

    <UserControl.DataContext>
        <viewmodels:MenuViewModel/>
    </UserControl.DataContext>

    <Grid Margin="28,24,28,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Page Header -->
        <Border BorderBrush="#072219" BorderThickness="0,0,0,1" Margin="0,0,0,20" Padding="0,0,0,14">
            <TextBlock Text="Menu Management"
                       FontSize="26"
                       FontWeight="Bold"
                       Foreground="#477C60"/>
        </Border>

        <!-- Main Content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1*"/>
                    <ColumnDefinition Width="2*"/>
                </Grid.ColumnDefinitions>

                <!-- Form Panel -->
                <Border Grid.Column="0"
                        Background="#090B17"
                        CornerRadius="10"
                        Padding="20"
                        Margin="0,0,12,0">
                    <StackPanel>
                        <TextBlock Text="Menu Item Details"
                                   FontSize="16"
                                   FontWeight="Bold"
                                   Foreground="#477C60"
                                   Margin="0,0,0,20"/>

                        <TextBlock Text="Name:" Foreground="#9CA3AF" FontWeight="Medium" Margin="0,0,0,4"/>
                        <TextBox Text="{Binding NewItemName, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,14"/>

                        <TextBlock Text="Category:" Foreground="#9CA3AF" FontWeight="Medium" Margin="0,0,0,4"/>
                        <TextBox Text="{Binding NewItemCategory, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,14"/>

                        <TextBlock Text="Price:" Foreground="#9CA3AF" FontWeight="Medium" Margin="0,0,0,4"/>
                        <TextBox Text="{Binding NewItemPrice, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,14"/>

                        <TextBlock Text="Description:" Foreground="#9CA3AF" FontWeight="Medium" Margin="0,0,0,4"/>
                        <TextBox Text="{Binding NewItemDescription, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,0,0,20"
                                 Height="80"
                                 TextWrapping="Wrap"
                                 AcceptsReturn="True"/>

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <Button Content="Add Item" Command="{Binding AddCommand}" Style="{StaticResource PrimaryButton}" Margin="0,0,8,0"/>
                            <Button Content="Update Item" Command="{Binding UpdateCommand}" Style="{StaticResource SecondaryButton}" Margin="0,0,8,0"/>
                            <Button Content="Clear" Command="{Binding ClearFormCommand}" Style="{StaticResource SecondaryButton}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Items List Panel -->
                <Border Grid.Column="1"
                        Background="#090B17"
                        CornerRadius="10"
                        Padding="20"
                        Margin="12,0,0,0">
                    <StackPanel>
                        <TextBlock Text="Menu Items"
                                   FontSize="16"
                                   FontWeight="Bold"
                                   Foreground="#477C60"
                                   Margin="0,0,0,20"/>

                        <DataGrid ItemsSource="{Binding MenuItems}"
                                  SelectedItem="{Binding SelectedMenuItem}"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  CanUserDeleteRows="False"
                                  SelectionMode="Single"
                                  GridLinesVisibility="None"
                                  HeadersVisibility="Column"
                                  ColumnHeaderHeight="44"
                                  RowHeight="48"
                                  Background="#090B17"
                                  BorderThickness="0">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="ID"          Binding="{Binding Id}"          Width="60"  IsReadOnly="True"/>
                                <DataGridTextColumn Header="Name"        Binding="{Binding Name}"        Width="*"   IsReadOnly="True"/>
                                <DataGridTextColumn Header="Category"    Binding="{Binding Category}"    Width="*"   IsReadOnly="True"/>
                                <DataGridTextColumn Header="Price"       Binding="{Binding Price, StringFormat=C}" Width="*" IsReadOnly="True"/>
                                <DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="*"   IsReadOnly="True"/>
                                <DataGridTemplateColumn Header="Actions" Width="100">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Content="Delete"
                                                    Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"
                                                    Style="{StaticResource DangerButton}"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </Border>
            </Grid>
        </ScrollViewer>
    </Grid>
</UserControl>
