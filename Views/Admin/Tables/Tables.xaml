<UserControl x:Class="SihyuPOSPayroll.Views.Admin.Tables.Tables"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#000000">
    <Grid Margin="28,24,28,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Page Header -->
        <Border BorderBrush="#072219" BorderThickness="0,0,0,1" Margin="0,0,0,20" Padding="0,0,0,14">
            <TextBlock Text="Tables Management"
                       FontSize="26"
                       FontWeight="Bold"
                       Foreground="#477C60"/>
        </Border>

        <Border Grid.Row="1" Background="#090B17" CornerRadius="10" Padding="0">
            <DataGrid ItemsSource="{Binding Tables}"
                      SelectedItem="{Binding Selected, Mode=TwoWay}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      IsReadOnly="True"
                      BorderThickness="0"
                      Background="#090B17"
                      ColumnHeaderHeight="44"
                      RowHeight="48">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID"           Binding="{Binding Id}"          Width="Auto"/>
                    <DataGridTextColumn Header="Table Number" Binding="{Binding TableNumber}" Width="*"/>
                    <DataGridTextColumn Header="Status"       Binding="{Binding Status}"      Width="*"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</UserControl>
