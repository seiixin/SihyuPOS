<UserControl x:Class="SihyuPOSPayroll.Views.Admin.Inventory.Inventory"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:SihyuPOSPayroll.ViewModels"
             xmlns:helpers="clr-namespace:SihyuPOSPayroll.Helpers"
             xmlns:views="clr-namespace:SihyuPOSPayroll.Views.Admin.Inventory"
             Background="#000000">

    <UserControl.Resources>
        <helpers:EmptyStringToVisibilityConverter x:Key="EmptyStringToVisibilityConverter"/>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    </UserControl.Resources>

    <UserControl.DataContext>
        <vm:InventoryViewModel/>
    </UserControl.DataContext>

    <Grid Margin="28,24,28,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Page Header -->
        <Border BorderBrush="#072219" BorderThickness="0,0,0,1" Margin="0,0,0,20" Padding="0,0,0,14">
            <TextBlock FontSize="26"
                       FontWeight="Bold"
                       Foreground="#477C60">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Text" Value="Inventory &amp; Expiry Alerts"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsStoreMode}" Value="True">
                                <Setter Property="Text" Value="Inventory"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>
        </Border>

        <!-- Main content area -->
        <Grid Grid.Row="1">
            <StackPanel Orientation="Vertical">
                <!-- Search and Action Buttons -->
                <Grid Margin="0,0,0,14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="260"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Border Background="#090B17"
                            CornerRadius="8"
                            BorderBrush="#0D1117"
                            BorderThickness="1"
                            Padding="12,0"
                            Height="40"
                            Grid.Column="0">
                        <Grid>
                            <TextBlock Text="&#xE721;"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="13"
                                       Foreground="#6B7280"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Left"/>
                            <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     Foreground="#F3F4F6"
                                     VerticalContentAlignment="Center"
                                     Margin="22,0,0,0"/>
                            <TextBlock Text="Search Product or Category"
                                       Foreground="#6B7280"
                                       Margin="24,0,0,0"
                                       VerticalAlignment="Center"
                                       IsHitTestVisible="False"
                                       Visibility="{Binding SearchText, Converter={StaticResource EmptyStringToVisibilityConverter}}"/>
                        </Grid>
                    </Border>
                    <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="+ Add Item"
                                Command="{Binding AddItemCommand}"
                                Style="{StaticResource PrimaryButton}"
                                Margin="0,0,8,0"/>
                        <Button Content="Refresh"
                                Command="{Binding RefreshCommand}"
                                Style="{StaticResource SecondaryButton}"/>
                    </StackPanel>
                </Grid>

                <!-- Inventory Table -->
                <Border Background="#090B17" CornerRadius="10" Margin="0,0,0,20">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="300">
                        <DataGrid ItemsSource="{Binding FilteredItems}"
                                  SelectedItem="{Binding SelectedItem}"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  CanUserAddRows="False"
                                  BorderThickness="0"
                                  Background="#090B17"
                                  GridLinesVisibility="None"
                                  ColumnHeaderHeight="44"
                                  RowHeight="48">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Product Name" Binding="{Binding ProductName}" Width="*"/>
                                <DataGridTextColumn Header="Category" Binding="{Binding CategoryName}" Width="*"/>
                                <DataGridTextColumn Header="Quantity" Binding="{Binding Quantity}" Width="*"/>
                                <DataGridTextColumn Header="Expiry Date" Binding="{Binding ExpiryDate, StringFormat=\{0:yyyy-MM-dd\}}" Width="*"/>
                                <DataGridTemplateColumn Header="Actions" Width="120">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                <Button Content="Edit"
                                                        Style="{StaticResource SecondaryButton}"
                                                        Margin="0,0,8,0"
                                                        Command="{Binding DataContext.EditItemCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}"/>
                                                <Button Content="Delete"
                                                        Style="{StaticResource DangerButton}"
                                                        Command="{Binding DataContext.DeleteItemCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </ScrollViewer>
                </Border>

                <!-- Expiry Alerts Header -->
                <Grid Margin="0,0,0,12"
                      Visibility="{Binding IsRestaurantMode, Converter={StaticResource BoolToVisibilityConverter}}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Expiry Alerts"
                               FontSize="18"
                               FontWeight="Bold"
                               Foreground="#477C60"/>
                    <Border Grid.Column="1"
                            Background="#EF4444"
                            CornerRadius="8"
                            Padding="12,6">
                        <TextBlock Text="{Binding InventoryItems.Count, StringFormat=\{0\} Items}"
                                   Foreground="#FFFFFF"
                                   FontWeight="Bold"
                                   FontSize="13"/>
                    </Border>
                </Grid>

                <!-- Expiry Alerts Table -->
                <Border Background="#090B17" CornerRadius="10"
                        Visibility="{Binding IsRestaurantMode, Converter={StaticResource BoolToVisibilityConverter}}">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="200">
                        <DataGrid ItemsSource="{Binding InventoryItems}"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  CanUserAddRows="False"
                                  BorderThickness="0"
                                  Background="#090B17"
                                  GridLinesVisibility="None"
                                  ColumnHeaderHeight="44"
                                  RowHeight="48">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Product Name" Binding="{Binding ProductName}" Width="*"/>
                                <DataGridTextColumn Header="Quantity" Binding="{Binding Quantity}" Width="*"/>
                                <DataGridTextColumn Header="Expiry Date" Binding="{Binding ExpiryDate, StringFormat=\{0:yyyy-MM-dd\}}" Width="*"/>
                                <DataGridTemplateColumn Header="Status" Width="*">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border CornerRadius="6" Padding="12,6" HorizontalAlignment="Center">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="#128854"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Status}" Value="Expired">
                                                                <Setter Property="Background" Value="#EF4444"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Status}" Value="Expiring Soon">
                                                                <Setter Property="Background" Value="#F59E0B"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock Text="{Binding Status}"
                                                           Foreground="#000000"
                                                           FontWeight="Bold"
                                                           TextAlignment="Center"/>
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </ScrollViewer>
                </Border>
            </StackPanel>

            <!-- Dialog Overlay -->
            <Border Background="#80000000"
                    CornerRadius="8"
                    Padding="20"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Visibility" Value="Visible"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding CurrentDialog}" Value="{x:Null}">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <ContentPresenter Content="{Binding CurrentDialog}"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"/>
            </Border>
        </Grid>
    </Grid>
</UserControl>
