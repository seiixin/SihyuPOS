<UserControl x:Class="SihyuPOSPayroll.Views.Admin.Dashboard.Dashboard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#000000">

    <ScrollViewer VerticalScrollBarVisibility="Auto" Background="#000000">
        <StackPanel Margin="28,24,28,28" Orientation="Vertical" VerticalAlignment="Top" HorizontalAlignment="Stretch">

            <!-- Page Header -->
            <Border BorderBrush="#072219" BorderThickness="0,0,0,1" Margin="0,0,0,20" Padding="0,0,0,14">
                <TextBlock Text="Dashboard"
                           FontSize="26"
                           FontWeight="Bold"
                           Foreground="#477C60"/>
            </Border>

            <!-- Stats Cards Row -->
            <Grid Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Total Sales Card -->
                <Border Grid.Column="0" Background="#090B17" CornerRadius="10" Padding="20">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <Border Width="36" Height="36" Background="#072219" CornerRadius="8">
                                <TextBlock Text="&#xE8EC;"
                                           FontFamily="Segoe MDL2 Assets"
                                           FontSize="16"
                                           Foreground="#128854"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>
                        </StackPanel>
                        <TextBlock Text="254,021.24 PHP"
                                   FontSize="20"
                                   FontWeight="Bold"
                                   Foreground="#128854"
                                   Margin="0,0,0,4"/>
                        <TextBlock Text="Total Sales Today"
                                   FontSize="12"
                                   Foreground="#477C60"/>
                    </StackPanel>
                </Border>

                <!-- Active Employees Card -->
                <Border Grid.Column="2" Background="#090B17" CornerRadius="10" Padding="20">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <Border Width="36" Height="36" Background="#1A0A0A" CornerRadius="8">
                                <TextBlock Text="&#xE716;"
                                           FontFamily="Segoe MDL2 Assets"
                                           FontSize="16"
                                           Foreground="#F87171"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>
                        </StackPanel>
                        <TextBlock Text="29"
                                   FontSize="20"
                                   FontWeight="Bold"
                                   Foreground="#F87171"
                                   Margin="0,0,0,4"/>
                        <TextBlock Text="Active Employees"
                                   FontSize="12"
                                   Foreground="#9CA3AF"/>
                    </StackPanel>
                </Border>

                <!-- Low Inventory Card -->
                <Border Grid.Column="4" Background="#090B17" CornerRadius="10" Padding="20">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <Border Width="36" Height="36" Background="#0A1020" CornerRadius="8">
                                <TextBlock Text="&#xE8F1;"
                                           FontFamily="Segoe MDL2 Assets"
                                           FontSize="16"
                                           Foreground="#60A5FA"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>
                        </StackPanel>
                        <TextBlock Text="14"
                                   FontSize="20"
                                   FontWeight="Bold"
                                   Foreground="#60A5FA"
                                   Margin="0,0,0,4"/>
                        <TextBlock Text="Inventory Low Items"
                                   FontSize="12"
                                   Foreground="#9CA3AF"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Monthly Sales Chart -->
            <Border Background="#090B17" CornerRadius="10" Padding="20">
                <StackPanel>
                    <DockPanel Margin="0,0,0,16">
                        <TextBlock Text="SihyuPOS Monthly Sales"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="#F3F4F6"
                                   DockPanel.Dock="Left"
                                   VerticalAlignment="Center"/>
                        <ComboBox Width="140"
                                  DockPanel.Dock="Right"
                                  HorizontalAlignment="Right"
                                  SelectedIndex="0">
                            <ComboBoxItem Content="January"/>
                            <ComboBoxItem Content="February"/>
                            <ComboBoxItem Content="March"/>
                            <ComboBoxItem Content="April"/>
                            <ComboBoxItem Content="May"/>
                            <ComboBoxItem Content="June"/>
                            <ComboBoxItem Content="July"/>
                            <ComboBoxItem Content="August"/>
                            <ComboBoxItem Content="September"/>
                            <ComboBoxItem Content="October"/>
                            <ComboBoxItem Content="November"/>
                            <ComboBoxItem Content="December"/>
                        </ComboBox>
                    </DockPanel>
                    <Border Height="220" Background="#000000" CornerRadius="8" HorizontalAlignment="Stretch"
                            BorderBrush="#072219" BorderThickness="1">
                        <TextBlock Text="(Chart placeholder)"
                                   Foreground="#477C60"
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Center"
                                   FontSize="14"/>
                    </Border>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
