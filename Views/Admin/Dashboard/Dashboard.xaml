<UserControl x:Class="SihyuPOSPayroll.Views.Admin.Dashboard.Dashboard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BackgroundDarkBrush}">

    <StackPanel Margin="0" Orientation="Vertical" VerticalAlignment="Top">

        <!-- Header -->
        <DockPanel Margin="0,0,0,24">
            <TextBlock Text="Dashboard"
                       FontSize="28"
                       FontWeight="Bold"
                       Foreground="{StaticResource TextPrimaryBrush}"
                       DockPanel.Dock="Left" />
            <Button Content="🔔"
                    Width="40"
                    Height="40"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    Style="{StaticResource SecondaryButton}"
                    Padding="0"/>
        </DockPanel>

        <!-- Cards -->
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Stretch" Margin="0,0,0,24">
            <Border Style="{StaticResource CardBorder}" Margin="0,0,16,0" Width="*">
                <StackPanel>
                    <TextBlock Text="Total Sales Today" FontSize="14" Foreground="{StaticResource TextSecondaryBrush}" />
                    <TextBlock Text="₱254,021.24" FontSize="28" FontWeight="Bold" Foreground="{StaticResource AccentEmeraldBrush}" />
                </StackPanel>
            </Border>
            <Border Style="{StaticResource CardBorder}" Margin="8,0,8,0" Width="*">
                <StackPanel>
                    <TextBlock Text="Active Employees" FontSize="14" Foreground="{StaticResource TextSecondaryBrush}" />
                    <TextBlock Text="29" FontSize="28" FontWeight="Bold" Foreground="#3B82F6" />
                </StackPanel>
            </Border>
            <Border Style="{StaticResource CardBorder}" Margin="16,0,0,0" Width="*">
                <StackPanel>
                    <TextBlock Text="Inventory Low Items" FontSize="14" Foreground="{StaticResource TextSecondaryBrush}" />
                    <TextBlock Text="14" FontSize="28" FontWeight="Bold" Foreground="#F59E0B" />
                </StackPanel>
            </Border>
        </StackPanel>

        <!-- Monthly Sales -->
        <Border Style="{StaticResource CardBorder}">
            <StackPanel>
                <DockPanel Margin="0,0,0,16">
                    <TextBlock Text="Sihyu POS & Payroll Monthly Sales"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               DockPanel.Dock="Left" />
                    <ComboBox Width="140"
                              DockPanel.Dock="Right"
                              Height="40"
                              SelectedIndex="0">
                        <ComboBoxItem Content="January"/>
                        <ComboBoxItem Content="February"/>
                        <ComboBoxItem Content="March"/>
                        <ComboBoxItem Content="April"/>
                        <ComboBoxItem Content="May"/>
                        <ComboBoxItem Content="June"/>
                        <ComboBoxItem Content="July"/>
                        <ComboBoxItem Content="August"/>
                        <ComboBoxItem Content="September"/>
                        <ComboBoxItem Content="October"/>
                        <ComboBoxItem Content="November"/>
                        <ComboBoxItem Content="December"/>
                    </ComboBox>
                </DockPanel>
                <Border Height="200" 
                        Background="{StaticResource SurfaceLighterBrush}" 
                        CornerRadius="8" 
                        HorizontalAlignment="Stretch" 
                        VerticalAlignment="Center">
                    <TextBlock Text="(Chart placeholder)" 
                               Foreground="{StaticResource TextMutedBrush}" 
                               VerticalAlignment="Center" 
                               HorizontalAlignment="Center"
                               FontSize="14"/>
                </Border>
            </StackPanel>
        </Border>
    </StackPanel>
</UserControl>
