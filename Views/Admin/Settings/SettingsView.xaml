<UserControl x:Class="SihyuPOSPayroll.Views.Admin.Settings.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:helpers="clr-namespace:SihyuPOSPayroll.Helpers"
             xmlns:models="clr-namespace:SihyuPOSPayroll.Models"
             Background="#000000">

    <UserControl.Resources>
        <helpers:EnumToBoolConverter x:Key="EnumToBoolConverter"/>
        <helpers:EmptyStringToVisibilityConverter x:Key="EmptyStringToVisibilityConverter"/>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="28,24,28,24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Page Header -->
            <Border BorderBrush="#072219" BorderThickness="0,0,0,1" Margin="0,0,0,20" Padding="0,0,0,14" Grid.Row="0">
                <TextBlock Text="System Settings"
                           FontSize="26"
                           FontWeight="Bold"
                           Foreground="#477C60"/>
            </Border>

            <!-- Two-Column Card Layout -->
            <Grid Grid.Row="1" Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- LEFT CARD: Mode Selection -->
                <Border Style="{StaticResource CardBorder}" Grid.Column="0" VerticalAlignment="Top">
                    <StackPanel>
                        <!-- Card Header -->
                        <TextBlock Text="Mode Selection"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   Margin="0,0,0,6"/>
                        <TextBlock Text="Select the operating mode for this deployment."
                                   FontSize="13"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,20"/>

                        <!-- Restaurant Mode -->
                        <Border Background="#0F1220"
                                CornerRadius="8"
                                BorderBrush="#1A1D2E"
                                BorderThickness="1"
                                Padding="16"
                                Margin="0,0,0,12">
                            <RadioButton GroupName="Mode"
                                         IsChecked="{Binding SelectedMode, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=RestaurantMode}"
                                         Cursor="Hand">
                                <RadioButton.Content>
                                    <StackPanel Margin="8,0,0,0">
                                        <TextBlock Text="Inventory, POS &amp; Menu for Restaurant"
                                                   FontWeight="SemiBold"
                                                   FontSize="14"
                                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                                        <TextBlock Text="Enables full inventory, POS, and menu management with recipe-based ingredient tracking and dine-in/take-out awareness."
                                                   FontSize="12"
                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                   TextWrapping="Wrap"
                                                   Margin="0,4,0,0"/>
                                    </StackPanel>
                                </RadioButton.Content>
                            </RadioButton>
                        </Border>

                        <!-- Store Mode -->
                        <Border Background="#0F1220"
                                CornerRadius="8"
                                BorderBrush="#1A1D2E"
                                BorderThickness="1"
                                Padding="16">
                            <RadioButton GroupName="Mode"
                                         IsChecked="{Binding SelectedMode, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=StoreMode}"
                                         Cursor="Hand">
                                <RadioButton.Content>
                                    <StackPanel Margin="8,0,0,0">
                                        <TextBlock Text="Inventory &amp; POS for Store"
                                                   FontWeight="SemiBold"
                                                   FontSize="14"
                                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                                        <TextBlock Text="Simplified retail inventory and POS with per-unit deduction. Menu module is disabled."
                                                   FontSize="12"
                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                   TextWrapping="Wrap"
                                                   Margin="0,4,0,0"/>
                                    </StackPanel>
                                </RadioButton.Content>
                            </RadioButton>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- Spacer -->
                <Grid Grid.Column="1"/>

                <!-- RIGHT CARD: Module Visibility -->
                <Border Style="{StaticResource CardBorder}" Grid.Column="2" VerticalAlignment="Top">
                    <StackPanel>
                        <!-- Card Header -->
                        <TextBlock Text="Module Visibility"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   Margin="0,0,0,6"/>
                        <TextBlock Text="Enable or disable sidebar modules for all user roles."
                                   FontSize="13"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,16"/>

                        <!-- Module list -->
                        <ItemsControl ItemsSource="{Binding ModuleConfigs}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#0F1220"
                                            CornerRadius="6"
                                            BorderBrush="#1A1D2E"
                                            BorderThickness="1"
                                            Padding="12,10"
                                            Margin="0,0,0,6">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- Module name -->
                                            <TextBlock Text="{Binding ModuleName}"
                                                       FontSize="14"
                                                       FontWeight="Medium"
                                                       Foreground="{StaticResource TextPrimaryBrush}"
                                                       VerticalAlignment="Center"/>

                                            <!-- CheckBox column — disabled when IsLocked=true -->
                                            <CheckBox Grid.Column="1"
                                                      IsChecked="{Binding IsEnabled, Mode=TwoWay}"
                                                      VerticalAlignment="Center"
                                                      Cursor="Hand">
                                                <CheckBox.Style>
                                                    <Style TargetType="CheckBox" BasedOn="{StaticResource {x:Type CheckBox}}">
                                                        <Style.Triggers>
                                                            <!-- Disable the CheckBox control when IsLocked = true -->
                                                            <DataTrigger Binding="{Binding IsLocked}" Value="True">
                                                                <Setter Property="IsEnabled" Value="False"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </CheckBox.Style>
                                                <CheckBox.ToolTip>
                                                    <ToolTip>
                                                        <ToolTip.Style>
                                                            <Style TargetType="ToolTip">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsLocked}" Value="True">
                                                                        <Setter Property="Visibility" Value="Visible"/>
                                                                        <Setter Property="Content" Value="This module cannot be disabled."/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </ToolTip.Style>
                                                    </ToolTip>
                                                </CheckBox.ToolTip>
                                            </CheckBox>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Bottom: Save Button and Result Message -->
            <Border Grid.Row="2" Padding="0,8,0,0">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <!-- Save result message — visible whenever SaveResultMessage is non-null -->
                    <TextBlock Text="{Binding SaveResultMessage}"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               VerticalAlignment="Center"
                               Margin="0,0,16,0"
                               FontSize="13"
                               Visibility="{Binding SaveResultMessage, Converter={StaticResource EmptyStringToVisibilityConverter}}"/>

                    <!-- Save button -->
                    <Button Content="Save Settings"
                            Command="{Binding SaveCommand}"
                            Style="{StaticResource PrimaryButton}"
                            Padding="20,10"
                            FontSize="14"/>
                </StackPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</UserControl>
