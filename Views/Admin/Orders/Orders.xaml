<UserControl
    x:Class="SihyuPOSPayroll.Views.Admin.Orders.Orders"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="#000000">

    <Grid Margin="28,24,28,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Page Header -->
        <Border BorderBrush="#072219" BorderThickness="0,0,0,1" Margin="0,0,0,20" Padding="0,0,0,14">
            <TextBlock Text="Orders"
                       FontSize="26"
                       FontWeight="Bold"
                       Foreground="#477C60"/>
        </Border>

        <!-- Search bar only (no Add button) -->
        <Grid Grid.Row="1" Margin="0,0,0,14">
            <Border Background="#090B17"
                    CornerRadius="8"
                    BorderBrush="#0D1117"
                    BorderThickness="1"
                    Padding="12,0"
                    Height="40">
                <Grid>
                    <TextBlock Text="&#xE721;"
                               FontFamily="Segoe MDL2 Assets"
                               FontSize="13"
                               Foreground="#6B7280"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Left"/>
                    <TextBox x:Name="SearchBox"
                             Background="Transparent"
                             BorderThickness="0"
                             Foreground="#F3F4F6"
                             VerticalContentAlignment="Center"
                             Margin="22,0,0,0"
                             TextChanged="SearchBox_TextChanged"
                             ToolTip="Search by table, payment, status"/>
                </Grid>
            </Border>
        </Grid>

        <!-- Orders Grid -->
        <Border Grid.Row="2" Background="#090B17" CornerRadius="10" Padding="0">
            <DataGrid x:Name="OrdersGrid"
                      ItemsSource="{Binding Orders}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      IsReadOnly="True"
                      ColumnHeaderHeight="44"
                      RowHeight="48"
                      Background="#090B17"
                      BorderThickness="0"
                      SelectionMode="Single"
                      SelectionUnit="FullRow">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Date"    Binding="{Binding CreatedAt, StringFormat=\{0:MM/dd/yy HH:mm\}}" Width="2*" />
                    <DataGridTextColumn Header="Table"   Binding="{Binding TableNumber}" Width="1.2*" />
                    <DataGridTextColumn Header="Total"   Binding="{Binding TotalAmount, StringFormat=₱{0:0.##}}" Width="1.2*" />
                    <DataGridTextColumn Header="Payment" Binding="{Binding PaymentStatus}" Width="1.2*" />
                    <DataGridTextColumn Header="Status"  Binding="{Binding OrderStatus}" Width="1.4*" />
                    <DataGridTemplateColumn Header="Actions" Width="1.6*">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <Button Content="Details"
                                            Style="{StaticResource SecondaryButton}"
                                            Margin="0,0,6,0"
                                            Click="InfoOrder_Click"/>
                                    <Button Content="Delete"
                                            Style="{StaticResource DangerButton}"
                                            Click="DeleteOrder_Click"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- READ-ONLY DETAILS OVERLAY -->
        <Grid x:Name="InfoPanel"
              Visibility="Collapsed"
              Background="#AA000000"
              Grid.RowSpan="3">
            <Border Background="#090B17"
                    BorderBrush="#072219"
                    BorderThickness="1"
                    CornerRadius="12"
                    Padding="24"
                    MaxWidth="900" MaxHeight="620"
                    HorizontalAlignment="Center" VerticalAlignment="Center">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Details header -->
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Orientation="Vertical">
                            <TextBlock Text="Order Details"
                                       FontSize="20" FontWeight="Bold" Foreground="#477C60"/>
                            <TextBlock Margin="0,8,0,0" Foreground="#9CA3AF">
                                <Run Text="Order #"/>
                                <Run Text="{Binding InfoOrder.Id}" FontWeight="Bold"/>
                                <Run Text=" · Date:"/>
                                <Run Text="{Binding InfoOrder.CreatedAt, StringFormat=\{0:MM/dd/yy HH:mm\}}"/>
                                <Run Text=" · Table:"/>
                                <Run Text="{Binding InfoOrder.TableNumber}"/>
                            </TextBlock>
                            <TextBlock Margin="0,4,0,0" Foreground="#9CA3AF">
                                <Run Text="Payment:"/>
                                <Run Text="{Binding InfoOrder.PaymentStatus}" FontWeight="Bold"/>
                                <Run Text=" · Status:"/>
                                <Run Text="{Binding InfoOrder.OrderStatus}" FontWeight="Bold"/>
                                <Run Text=" · Total:"/>
                                <Run Text="{Binding InfoOrder.TotalAmount, StringFormat=₱{0:0.##}}" FontWeight="Bold"/>
                            </TextBlock>
                        </StackPanel>
                        <Button Grid.Column="1"
                                Content="Close"
                                Style="{StaticResource SecondaryButton}"
                                Click="CloseInfo_Click"/>
                    </Grid>

                    <!-- Items read-only grid -->
                    <DataGrid Grid.Row="1"
                              ItemsSource="{Binding InfoItems}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              IsReadOnly="True"
                              Background="#090B17"
                              BorderThickness="0">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Product"    Binding="{Binding ProductName}"                             Width="2*" />
                            <DataGridTextColumn Header="Category"   Binding="{Binding Category}"                               Width="1.2*" />
                            <DataGridTextColumn Header="Qty"        Binding="{Binding Quantity}"                               Width="0.8*" />
                            <DataGridTextColumn Header="Unit Price" Binding="{Binding UnitPrice, StringFormat=₱{0:0.##}}"     Width="1.2*" />
                            <DataGridTextColumn Header="Subtotal"   Binding="{Binding Subtotal,   StringFormat=₱{0:0.##}}"    Width="1.2*" />
                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- Footer -->
                    <StackPanel Grid.Row="2" Orientation="Horizontal"
                                HorizontalAlignment="Right" Margin="0,16,0,0">
                        <Button Content="Close"
                                Style="{StaticResource SecondaryButton}"
                                Click="CloseInfo_Click"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
