<Window x:Class="SihyuPOSPayroll.Views.Admin.DashboardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Admin Dashboard - SihyuPOS &amp; Payroll"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        ResizeMode="CanResize">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Border Background="{StaticResource SurfaceDarkBrush}">
            <StackPanel Margin="0,30" HorizontalAlignment="Center">
                <Ellipse Width="68" Height="62" Fill="{StaticResource SurfaceLighterBrush}"/>
                <TextBlock Text="ADMIN" FontWeight="Bold" FontSize="16" Margin="0,10,0,0" TextAlignment="Center" Foreground="{StaticResource TextPrimaryBrush}"/>
                <TextBlock Text="(First Last)" FontSize="12" HorizontalAlignment="Center" Margin="0,0,0,20" Foreground="{StaticResource TextSecondaryBrush}"/>

                <!-- Simplified ListBox using Items -->
                <ListBox Background="Transparent"
                         BorderThickness="0"
                         Width="220"
                         HorizontalAlignment="Center">
                    <ListBoxItem Content="Dashboard"/>
                    <ListBoxItem Content="Users"/>
                    <ListBoxItem Content="Employees"/>
                    <ListBoxItem Content="Payroll"/>
                    <ListBoxItem Content="Payslip Requests"/>
                    <ListBoxItem Content="Attendance"/>
                    <ListBoxItem Content="Menu"/>
                    <ListBoxItem Content="Inventory"/>
                    <ListBoxItem Content="Orders"/>
                    <ListBoxItem Content="Receipts"/>
                    <ListBoxItem Content="Tables"/>
                    <ListBoxItem Content="Sales &amp; Reports"/>
                    <ListBoxItem Content="Logout"/>
                </ListBox>
            </StackPanel>
        </Border>

        <!-- Main Content -->
        <Border Grid.Column="1" Background="{StaticResource BackgroundDarkBrush}" Margin="15">
            <TextBlock Text="Select a page from the sidebar"
                       Foreground="{StaticResource TextPrimaryBrush}"
                       FontSize="28"
                       FontWeight="Bold"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>
        </Border>
    </Grid>
</Window>