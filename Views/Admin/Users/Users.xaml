<UserControl
    x:Class="SihyuPOSPayroll.Views.Admin.Users.Users"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:helpers="clr-namespace:SihyuPOSPayroll.Helpers"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    mc:Ignorable="d"
    Background="#000000"
    d:DesignHeight="500" d:DesignWidth="800">

    <UserControl.Resources>
        <helpers:EmptyStringToVisibilityConverter x:Key="EmptyStringToVisibilityConverter" />
    </UserControl.Resources>

    <Grid x:Name="RootGrid" Margin="28,24,28,24">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Page Header -->
        <Border BorderBrush="#072219" BorderThickness="0,0,0,1" Margin="0,0,0,20" Padding="0,0,0,14">
            <TextBlock Text="Users &amp; Roles Management"
                       FontSize="26"
                       FontWeight="Bold"
                       Foreground="#477C60"/>
        </Border>

        <!-- Search & Add Button -->
        <Grid Grid.Row="1" Margin="0,0,0,14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!-- Search box -->
            <Border Background="#090B17"
                    CornerRadius="8"
                    BorderBrush="#0D1117"
                    BorderThickness="1"
                    Padding="12,0"
                    Height="40"
                    Margin="0,0,12,0">
                <Grid>
                    <TextBlock Text="&#xE721;"
                               FontFamily="Segoe MDL2 Assets"
                               FontSize="13"
                               Foreground="#6B7280"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Left"
                               Margin="0,0,8,0"/>
                    <TextBox x:Name="SearchBox"
                             Background="Transparent"
                             BorderThickness="0"
                             Foreground="#F3F4F6"
                             VerticalContentAlignment="Center"
                             Margin="20,0,0,0"
                             TextChanged="SearchBox_TextChanged" />
                    <TextBlock Text="Search users..."
                               Foreground="#6B7280"
                               Margin="24,0,0,0"
                               VerticalAlignment="Center"
                               IsHitTestVisible="False"
                               Visibility="{Binding Text.Length, Converter={StaticResource EmptyStringToVisibilityConverter}, ElementName=SearchBox}" />
                </Grid>
            </Border>

            <!-- Add User Button -->
            <Button x:Name="AddUserButton"
                    Grid.Column="1"
                    Content="+ Add User"
                    Style="{StaticResource PrimaryButton}"
                    Padding="18,10"
                    Click="AddUser_Click"/>
        </Grid>

        <!-- DataGrid -->
        <Border Grid.Row="2" Background="#090B17" CornerRadius="10" Padding="0">
            <DataGrid x:Name="UserDataGrid"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      IsReadOnly="True"
                      ColumnHeaderHeight="44"
                      RowHeight="48"
                      Background="#090B17"
                      BorderThickness="0"
                      RowBackground="#090B17"
                      AlternatingRowBackground="#000000">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="*" />
                    <DataGridTextColumn Header="Role" Binding="{Binding Role}" Width="*" />
                    <DataGridTextColumn Header="Linked Employee" Binding="{Binding Employee.FullName}" Width="*" />
                    <DataGridTemplateColumn Header="Actions" Width="180">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <Button Content="Edit"
                                            ToolTip="Edit"
                                            Style="{StaticResource SecondaryButton}"
                                            Padding="12,6"
                                            Click="EditUser_Click"
                                            Margin="0,0,8,0"/>
                                    <Button Content="Delete"
                                            ToolTip="Delete"
                                            Style="{StaticResource DangerButton}"
                                            Padding="12,6"
                                            Click="DeleteUser_Click"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</UserControl>
