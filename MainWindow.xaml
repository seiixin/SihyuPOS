<Window x:Class="SihyuPOSPayroll.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        Title="Login - SihyuPOS &amp; Payroll"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        WindowState="Maximized"
        Background="#000000">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Background with Abstract Orbs -->
        <Grid Grid.ColumnSpan="2">
            <!-- Deep Dark Background -->
            <Border Background="#05080A"/>

            <!-- Left Large Orb -->
            <Ellipse Width="400" Height="400">
                <Ellipse.Fill>
                    <RadialGradientBrush Center="0.5,0.5" RadiusX="0.5" RadiusY="0.5">
                        <GradientStop Color="#10B981" Offset="0" />
                        <GradientStop Color="#00000000" Offset="1" />
                    </RadialGradientBrush>
                </Ellipse.Fill>
                <Ellipse.RenderTransform>
                    <TranslateTransform X="-100" Y="-150"/>
                </Ellipse.RenderTransform>
                <Ellipse.Effect>
                    <BlurEffect Radius="60"/>
                </Ellipse.Effect>
            </Ellipse>

            <!-- Bottom Left Orb -->
            <Ellipse Width="250" Height="250"
                     VerticalAlignment="Bottom"
                     HorizontalAlignment="Left">
                <Ellipse.Fill>
                    <RadialGradientBrush Center="0.5,0.5" RadiusX="0.5" RadiusY="0.5">
                        <GradientStop Color="#34D399" Offset="0" />
                        <GradientStop Color="#00000000" Offset="1" />
                    </RadialGradientBrush>
                </Ellipse.Fill>
                <Ellipse.RenderTransform>
                    <TranslateTransform X="80" Y="80"/>
                </Ellipse.RenderTransform>
                <Ellipse.Effect>
                    <BlurEffect Radius="60"/>
                </Ellipse.Effect>
            </Ellipse>

            <!-- Right Large Orb -->
            <Ellipse Width="400" Height="400"
                     HorizontalAlignment="Right"
                     VerticalAlignment="Bottom">
                <Ellipse.Fill>
                    <RadialGradientBrush Center="0.5,0.5" RadiusX="0.5" RadiusY="0.5">
                        <GradientStop Color="#059669" Offset="0" />
                        <GradientStop Color="#00000000" Offset="1" />
                    </RadialGradientBrush>
                </Ellipse.Fill>
                <Ellipse.RenderTransform>
                    <TranslateTransform X="150" Y="100"/>
                </Ellipse.RenderTransform>
                <Ellipse.Effect>
                    <BlurEffect Radius="60"/>
                </Ellipse.Effect>
            </Ellipse>

            <!-- Right Middle Orb -->
            <Ellipse Width="200" Height="200"
                     HorizontalAlignment="Right"
                     VerticalAlignment="Center">
                <Ellipse.Fill>
                    <RadialGradientBrush Center="0.5,0.5" RadiusX="0.5" RadiusY="0.5">
                        <GradientStop Color="#10B981" Offset="0" />
                        <GradientStop Color="#00000000" Offset="1" />
                    </RadialGradientBrush>
                </Ellipse.Fill>
                <Ellipse.RenderTransform>
                    <TranslateTransform X="100" Y="0"/>
                </Ellipse.RenderTransform>
                <Ellipse.Effect>
                    <BlurEffect Radius="50"/>
                </Ellipse.Effect>
            </Ellipse>

            <!-- Subtle Noise Overlay -->
            <Grid Opacity="0.03">
                <Grid.Background>
                    <VisualBrush Stretch="UniformToFill" TileMode="Tile" ViewportUnits="Absolute" ViewboxUnits="Absolute" Viewport="0,0,100,100" Viewbox="0,0,100,100">
                        <VisualBrush.Visual>
                            <Canvas Width="100" Height="100">
                                <!-- Dots for noise texture -->
                                <Ellipse Canvas.Left="10" Canvas.Top="15" Width="1" Height="1" Fill="#FFFFFF"/>
                                <Ellipse Canvas.Left="30" Canvas.Top="25" Width="1" Height="1" Fill="#34D399"/>
                                <Ellipse Canvas.Left="50" Canvas.Top="10" Width="1" Height="1" Fill="#10B981"/>
                                <Ellipse Canvas.Left="70" Canvas.Top="35" Width="1" Height="1" Fill="#FFFFFF"/>
                                <Ellipse Canvas.Left="90" Canvas.Top="45" Width="1" Height="1" Fill="#34D399"/>
                                <Ellipse Canvas.Left="20" Canvas.Top="60" Width="1" Height="1" Fill="#10B981"/>
                                <Ellipse Canvas.Left="40" Canvas.Top="80" Width="1" Height="1" Fill="#FFFFFF"/>
                                <Ellipse Canvas.Left="60" Canvas.Top="75" Width="1" Height="1" Fill="#34D399"/>
                                <Ellipse Canvas.Left="80" Canvas.Top="55" Width="1" Height="1" Fill="#10B981"/>
                                <Ellipse Canvas.Left="5" Canvas.Top="90" Width="1" Height="1" Fill="#FFFFFF"/>
                            </Canvas>
                        </VisualBrush.Visual>
                    </VisualBrush>
                </Grid.Background>
            </Grid>
        </Grid>

        <!-- Left Panel -->
        <Border Grid.Column="0">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="20">
                <!-- Welcome Text -->
                <StackPanel Orientation="Vertical" TextBlock.TextAlignment="Center">
                    <TextBlock FontFamily="Segoe UI, Roboto, Helvetica, Arial, sans-serif"
                               FontSize="42"
                               FontWeight="ExtraBold"
                               Foreground="#F3F4F6"
                               Text="Welcome to ">
                    </TextBlock>
                    <TextBlock FontFamily="Segoe UI, Roboto, Helvetica, Arial, sans-serif"
                               FontSize="42"
                               FontWeight="ExtraBold"
                               Foreground="#34D399"
                               Text="SihyuPOS">
                        <TextBlock.Effect>
                            <DropShadowEffect BlurRadius="30" Color="#10B981" ShadowDepth="0" Opacity="0.7"/>
                        </TextBlock.Effect>
                    </TextBlock>
                </StackPanel>

                <TextBlock Text="Connect with your team."
                               FontFamily="Segoe UI, Roboto, Helvetica, Arial, sans-serif"
                               Foreground="#9CA3AF"
                               FontSize="18"
                               TextWrapping="Wrap"
                               TextAlignment="Center"
                               Margin="0,25,0,0"
                               Width="420"/>
            </StackPanel>
        </Border>

        <!-- Right Panel -->
        <Border Grid.Column="1">
            <Border 
                Background="#111827"
                CornerRadius="24"
                Padding="55"
                Width="480"
                Height="Auto"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                BorderBrush="#2D3748"
                BorderThickness="1">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="30" Color="#000000" ShadowDepth="0" Opacity="0.6"/>
                </Border.Effect>

                <StackPanel>
                    <TextBlock Text="LOGIN"
                               FontFamily="Segoe UI, Roboto, Helvetica, Arial, sans-serif"
                               FontSize="36"
                               FontWeight="ExtraBold"
                               Foreground="#34D399"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,35">
                        <TextBlock.Effect>
                            <DropShadowEffect BlurRadius="20" Color="#10B981" ShadowDepth="0" Opacity="0.5"/>
                        </TextBlock.Effect>
                    </TextBlock>

                    <!-- Email Input -->
                    <Border Margin="0,0,0,20">
                        <Grid>
                            <TextBox x:Name="EmailTextBox" 
                                     Text=""
                                     Height="58"
                                     Padding="18,0"
                                     FontFamily="Segoe UI, Roboto, Helvetica, Arial, sans-serif"
                                     FontSize="14"
                                     BorderThickness="2"
                                     Background="#0B0F19"
                                     Foreground="#F3F4F6"
                                     TextChanged="EmailTextBox_TextChanged"
                                     GotFocus="Input_GotFocus"
                                     LostFocus="Input_LostFocus"
                                     BorderBrush="#2D3748">
                                <TextBox.Style>
                                    <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="TextBox">
                                                    <Border x:Name="Border"
                                                            Background="{TemplateBinding Background}"
                                                            BorderBrush="{TemplateBinding BorderBrush}"
                                                            BorderThickness="{TemplateBinding BorderThickness}"
                                                            CornerRadius="12">
                                                        <Border.Effect>
                                                            <DropShadowEffect BlurRadius="0" Color="#10B981" ShadowDepth="0" Opacity="0"/>
                                                        </Border.Effect>
                                                        <ScrollViewer x:Name="PART_ContentHost"
                                                                      VerticalAlignment="Center"
                                                                      Margin="0"
                                                                      Padding="0"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsFocused" Value="True">
                                                            <Setter TargetName="Border" Property="BorderBrush" Value="#10B981"/>
                                                            <Setter TargetName="Border" Property="Effect">
                                                                <Setter.Value>
                                                                    <DropShadowEffect BlurRadius="20" Color="#10B981" ShadowDepth="0" Opacity="0.5"/>
                                                                </Setter.Value>
                                                            </Setter>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </TextBox.Style>
                            </TextBox>
                            <TextBlock x:Name="EmailPlaceholderText"
                                       Text="admin@sihyupos.com"
                                       Foreground="#6B7280"
                                       FontSize="14"
                                       Padding="18,0"
                                       IsHitTestVisible="False"
                                       VerticalAlignment="Center"
                                       Margin="2"/>
                        </Grid>
                    </Border>

                    <!-- Password Input -->
                    <Border Margin="0,0,0,20">
                        <Grid>
                            <PasswordBox x:Name="PasswordBox"
                                         Height="58"
                                         Padding="18,0"
                                         FontFamily="Segoe UI, Roboto, Helvetica, Arial, sans-serif"
                                         FontSize="14"
                                         BorderThickness="2"
                                         Background="#0B0F19"
                                         Foreground="#F3F4F6"
                                         PasswordChanged="PasswordBox_PasswordChanged"
                                         BorderBrush="#2D3748">
                                <PasswordBox.Style>
                                    <Style TargetType="PasswordBox" BasedOn="{StaticResource {x:Type PasswordBox}}">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="PasswordBox">
                                                    <Border x:Name="Border"
                                                            Background="{TemplateBinding Background}"
                                                            BorderBrush="{TemplateBinding BorderBrush}"
                                                            BorderThickness="{TemplateBinding BorderThickness}"
                                                            CornerRadius="12">
                                                        <Border.Effect>
                                                            <DropShadowEffect BlurRadius="0" Color="#10B981" ShadowDepth="0" Opacity="0"/>
                                                        </Border.Effect>
                                                        <ScrollViewer x:Name="PART_ContentHost"
                                                                      VerticalAlignment="Center"
                                                                      Margin="0"
                                                                      Padding="0"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsFocused" Value="True">
                                                            <Setter TargetName="Border" Property="BorderBrush" Value="#10B981"/>
                                                            <Setter TargetName="Border" Property="Effect">
                                                                <Setter.Value>
                                                                    <DropShadowEffect BlurRadius="20" Color="#10B981" ShadowDepth="0" Opacity="0.5"/>
                                                                </Setter.Value>
                                                            </Setter>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </PasswordBox.Style>
                            </PasswordBox>

                            <TextBlock x:Name="PasswordPlaceholder"
                                       Text="••••••••"
                                       Foreground="#6B7280"
                                       FontSize="14"
                                       Padding="18,0"
                                       IsHitTestVisible="False"
                                       VerticalAlignment="Center"
                                       Margin="2"/>

                            <Button Content="SHOW"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Foreground="#10B981"
                                    FontFamily="Segoe UI, Roboto, Helvetica, Arial, sans-serif"
                                    FontSize="14"
                                    FontWeight="Bold"
                                    Padding="0,0,18,0"
                                    HorizontalAlignment="Right"
                                    Click="TogglePassword_Click">
                            </Button>
                        </Grid>
                    </Border>

                    <!-- Remember Me -->
                    <CheckBox Content="Remember Me"
                              FontFamily="Segoe UI, Roboto, Helvetica, Arial, sans-serif"
                              Foreground="#9CA3AF"
                              FontSize="14"
                              Margin="0,0,0,30"
                              VerticalAlignment="Center">
                        <CheckBox.Style>
                            <Style TargetType="CheckBox">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="CheckBox">
                                            <StackPanel Orientation="Horizontal">
                                                <Border Width="24" Height="24"
                                                        Background="#0B0F19"
                                                        BorderBrush="#2D3748"
                                                        BorderThickness="2"
                                                        CornerRadius="4"
                                                        Margin="0,0,12,0">
                                                    <Path x:Name="CheckMark"
                                                          Data="M 3 12 L 9 18 L 21 6"
                                                          Stroke="#10B981"
                                                          StrokeThickness="3"
                                                          Fill="Transparent"
                                                          Visibility="Collapsed"/>
                                                </Border>
                                                <ContentPresenter VerticalAlignment="Center"/>
                                            </StackPanel>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsChecked" Value="True">
                                                    <Setter TargetName="CheckMark" Property="Visibility" Value="Visible"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </CheckBox.Style>
                    </CheckBox>

                    <!-- Login Button -->
                    <Button Content="LOGIN"
                            FontFamily="Segoe UI, Roboto, Helvetica, Arial, sans-serif"
                            FontSize="18"
                            FontWeight="Bold"
                            Foreground="#0B0F19"
                            Height="58"
                            Margin="0,0,0,20"
                            Click="LoginButton_Click"
                            Cursor="Hand">
                        <Button.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#10B981" Offset="0" />
                                <GradientStop Color="#059669" Offset="1" />
                            </LinearGradientBrush>
                        </Button.Background>
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="Border"
                                                    Background="{TemplateBinding Background}"
                                                    CornerRadius="12"
                                                    Padding="16,8">
                                                <Border.Effect>
                                                    <DropShadowEffect BlurRadius="25" Color="#10B981" ShadowDepth="0" Opacity="0.6"/>
                                                </Border.Effect>
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Border" Property="Effect">
                                                        <Setter.Value>
                                                            <DropShadowEffect BlurRadius="35" Color="#34D399" ShadowDepth="0" Opacity="0.8"/>
                                                        </Setter.Value>
                                                    </Setter>
                                                </Trigger>
                                                <Trigger Property="IsPressed" Value="True">
                                                    <Setter TargetName="Border" Property="Opacity" Value="0.8"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>

                    <!-- Error Message -->
                    <TextBlock Text="{Binding ErrorMessage}"
                               FontFamily="Segoe UI, Roboto, Helvetica, Arial, sans-serif"
                               FontSize="13"
                               Foreground="#F87171"
                               TextAlignment="Center"
                               TextWrapping="Wrap"
                               Margin="0,10,0,0">
                        <TextBlock.Effect>
                            <DropShadowEffect BlurRadius="15" Color="#EF4444" ShadowDepth="0" Opacity="0.8"/>
                        </TextBlock.Effect>
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ErrorMessage}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding ErrorMessage}" Value="">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding ErrorMessage}" Value="{x:Static sys:String.Empty}">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding ErrorMessage}" Value="Invalid email or password.">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>
            </Border>
        </Border>
    </Grid>
</Window>