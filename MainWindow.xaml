<Window x:Class="SihyuPOSPayroll.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Login - SihyuPOS &amp; Payroll"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        WindowState="Maximized">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Left Panel -->
        <Border Grid.Column="0" Background="{StaticResource SurfaceDarkBrush}">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="20">
                <TextBlock Text="Welcome to SihyuPOS &amp; Payroll"
                           Foreground="{StaticResource TextPrimaryBrush}" FontSize="20" FontWeight="Bold"
                           TextWrapping="Wrap" TextAlignment="Center" Margin="0 0 10 0"/>
                <TextBlock Text="Connect with your team"
                           Foreground="{StaticResource TextSecondaryBrush}" FontSize="14" TextAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Right Panel -->
        <Border Grid.Column="1" Background="{StaticResource BackgroundDarkBrush}">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="320" Margin="10">
                <TextBlock Text="LOGIN" FontSize="24" FontWeight="Bold"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           HorizontalAlignment="Center" Margin="0 0 20 0"/>

                <!-- Email TextBox-->
                <TextBox x:Name="EmailTextBox" 
                         Text="Email"
                         Foreground="{StaticResource TextMutedBrush}"
                         Margin="0 0 10 0"
                         Height="40"
                         TextChanged="EmailTextBox_TextChanged"
                         GotFocus="Input_GotFocus"
                         LostFocus="Input_LostFocus"/>

                <!-- Password Grid with Placeholder -->
                <Grid Margin="0 0 10 0">
                    <PasswordBox x:Name="PasswordBox"
                                 Height="40"
                                 PasswordChanged="PasswordBox_PasswordChanged"/>

                    <TextBlock x:Name="PasswordPlaceholder"
                               Text="Password"
                               Foreground="{StaticResource TextMutedBrush}" FontSize="14"
                               Padding="10"
                               IsHitTestVisible="False"
                               VerticalAlignment="Center"
                               Visibility="Visible"/>
                </Grid>

                <!-- Error Message Display -->
                <TextBlock Text="{Binding ErrorMessage}" 
                           Foreground="#EF4444" 
                           FontSize="12"
                           HorizontalAlignment="Center" 
                           Margin="0 5"
                           TextWrapping="Wrap">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Visible"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ErrorMessage}" Value="{x:Null}">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding ErrorMessage}" Value="">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

                <CheckBox Content="Remember Me" Margin="0 0 10 0"/>

                <Button Content="LOGIN" Style="{StaticResource PrimaryButton}" Height="40" Click="LoginButton_Click"/>

            </StackPanel>
        </Border>
    </Grid>
</Window>